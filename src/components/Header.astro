---
import { getLangFromUrl, useTranslations, localizedPath } from '../i18n/utils';
import LangSwitcher from './LangSwitcher.astro';
import ThemeToggle from './ThemeToggle.astro';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---
<header class="sticky top-0 z-40 border-b border-ink-200 dark:border-ink-800 bg-white/80 dark:bg-ink-950/80 backdrop-blur">
  <div class="container-wide flex flex-col sm:flex-row sm:items-center sm:justify-between sm:h-16 py-2 sm:py-0 gap-1 sm:gap-0">
    <a href={localizedPath(lang, '/')} class="flex items-center gap-2 group self-start sm:self-auto" aria-label={t('site.title')}>
      <img src="/logo-light.png" alt="" width="32" height="32" class="block dark:hidden w-8 h-8 object-contain" />
      <img src="/logo-dark.png" alt="" width="32" height="32" class="hidden dark:block w-8 h-8 object-contain" />
      <span class="font-semibold text-base sm:text-lg">{t('site.title')}</span>
    </a>
    <nav class="flex items-center justify-between sm:justify-end gap-1 sm:gap-3 text-sm w-full sm:w-auto">
      <button
        type="button"
        id="layout-mode-toggle"
        class="hidden sm:inline-flex items-center gap-1.5 px-2.5 py-1 rounded-md border border-ink-200 dark:border-ink-800 bg-white dark:bg-ink-900 hover:border-brand-500 hover:text-brand-700 dark:hover:text-brand-300 transition-colors text-xs font-medium"
        aria-label={t('nav.flowToggle')}
        title={t('nav.flowToggle')}
      >
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" class="w-4 h-4" aria-hidden="true">
          <rect x="3" y="4" width="18" height="4" rx="1"/>
          <rect x="3" y="10" width="18" height="4" rx="1"/>
          <rect x="3" y="16" width="18" height="4" rx="1"/>
        </svg>
        <span data-mode-label>{t('nav.modeStandard')}</span>
      </button>
      <a href={localizedPath(lang, '/')} class="p-2 hover:text-brand-600 inline-flex items-center justify-center" aria-label={t('nav.home')} title={t('nav.home')}>
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" class="w-5 h-5" aria-hidden="true">
          <path d="M3 11.5L12 4l9 7.5"/><path d="M5 10.5V20a1 1 0 0 0 1 1h4v-6h4v6h4a1 1 0 0 0 1-1v-9.5"/>
        </svg>
      </a>
      <a href={lang === 'tr' ? '/kategoriler' : '/en/categories'} class="p-2 hover:text-brand-600 inline-flex items-center justify-center" aria-label={t('nav.categories')} title={t('nav.categories')}>
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" class="w-5 h-5" aria-hidden="true">
          <rect x="3" y="3" width="7" height="7" rx="1.2"/><rect x="14" y="3" width="7" height="7" rx="1.2"/><rect x="3" y="14" width="7" height="7" rx="1.2"/><rect x="14" y="14" width="7" height="7" rx="1.2"/>
        </svg>
      </a>
      <a href={lang === 'tr' ? '/etiketler/' : '/en/tags/'} class="p-2 hover:text-brand-600 inline-flex items-center justify-center" aria-label={t('nav.tags')} title={t('nav.tags')}>
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" class="w-5 h-5" aria-hidden="true">
          <path d="M20.59 13.41 13.41 20.59a2 2 0 0 1-2.83 0l-7.17-7.17a2 2 0 0 1-.59-1.41V5a2 2 0 0 1 2-2h6.99a2 2 0 0 1 1.41.59l7.17 7.17a2 2 0 0 1 0 2.83z"/><circle cx="7.5" cy="7.5" r="1.4" fill="currentColor"/>
        </svg>
      </a>
      <a href={lang === 'tr' ? '/ara' : '/en/search'} class="p-2 hover:text-brand-600 inline-flex items-center justify-center" aria-label={t('nav.search')} title={t('nav.search')}>
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" class="w-5 h-5" aria-hidden="true">
          <circle cx="11" cy="11" r="7"/><path d="m20 20-3.5-3.5"/>
        </svg>
      </a>
      <LangSwitcher />
      <ThemeToggle />
      <a
        href={lang === 'tr' ? '/bilgi' : '/en/info'}
        class="inline-flex items-center justify-center w-6 h-6 rounded-full border border-blue-500 text-blue-600 dark:text-blue-400 dark:border-blue-400 text-xs font-bold italic font-serif leading-none hover:bg-blue-500 hover:text-white dark:hover:bg-blue-400 dark:hover:text-ink-950 transition-colors"
        aria-label={t('nav.info')}
        title={t('nav.info')}
      >i</a>
    </nav>
  </div>
  <script is:inline define:vars={{ standardLabel: t('nav.modeStandard'), flowLabel: t('nav.modeFlow') }}>
    (function () {
      var btn = document.getElementById('layout-mode-toggle');
      if (!btn) return;
      var labelEl = btn.querySelector('[data-mode-label]');
      function syncLabel() {
        var mode = document.documentElement.getAttribute('data-mode') === 'flow' ? 'flow' : 'standard';
        if (labelEl) labelEl.textContent = mode === 'flow' ? flowLabel : standardLabel;
        btn.setAttribute('aria-pressed', mode === 'flow' ? 'true' : 'false');
      }
      syncLabel();
      btn.addEventListener('click', function () {
        var current = document.documentElement.getAttribute('data-mode') === 'flow' ? 'flow' : 'standard';
        var next = current === 'flow' ? 'standard' : 'flow';
        if (next === 'flow') {
          document.documentElement.setAttribute('data-mode', 'flow');
        } else {
          document.documentElement.removeAttribute('data-mode');
        }
        try { localStorage.setItem('layoutMode', next); } catch (_) {}
        syncLabel();
      });
    })();
  </script>
</header>
