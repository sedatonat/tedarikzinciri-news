---
import { getTimelineData, type Lang } from '../lib/timeline';
import { getLangFromUrl } from '../i18n/utils';

interface Props {
  lang?: Lang;
}

const lang: Lang = Astro.props.lang ?? (getLangFromUrl(Astro.url) as Lang);
const years = await getTimelineData(lang);

const L = {
  aria: lang === 'tr' ? 'Tarih kaydırıcı' : 'Date timeline',
  haber: lang === 'tr' ? 'haber' : 'articles',
  kronoloji: lang === 'tr' ? 'Kronoloji' : 'Chronology',
};
const kronoHref = lang === 'tr' ? '/kronoloji/' : '/en/chronology/';

function pad2(n: number): string {
  return String(n).padStart(2, '0');
}
---
<aside
  class="timeline-rail hidden lg:flex flex-col fixed left-0 top-20 bottom-8 z-30 select-none bg-ink-100/85 dark:bg-ink-950/70 border-r border-ink-200 dark:border-ink-800 backdrop-blur-sm rounded-r-lg"
  aria-label={L.aria}
>
  <a
    href={kronoHref}
    class="timeline-krono group flex items-center gap-1.5 mx-2 mt-2 mb-1 px-2 py-1.5 rounded-md border border-ink-200/80 dark:border-ink-700/80 bg-white/80 dark:bg-ink-900/80 text-[11px] font-semibold uppercase tracking-wider text-brand-600 dark:text-brand-300 hover:border-brand-500 hover:bg-brand-50 dark:hover:bg-brand-900/40 transition-colors shrink-0"
    title={L.kronoloji}
  >
    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" class="w-3.5 h-3.5 shrink-0" aria-hidden="true">
      <path d="M4 6h8a3 3 0 0 1 0 6H9a3 3 0 0 0 0 6h10"/>
      <circle cx="6" cy="6" r="1.6" fill="currentColor" stroke="none"/>
      <circle cx="13" cy="12" r="1.6" fill="currentColor" stroke="none"/>
      <circle cx="11" cy="18" r="1.6" fill="currentColor" stroke="none"/>
      <path d="m17 15 3 3-3 3"/>
    </svg>
    <span class="leading-none truncate">{L.kronoloji}</span>
  </a>
  <div class="timeline-scroll flex-1 min-h-0 overflow-y-auto overflow-x-visible py-1 pl-3 pr-2 text-sm font-mono tabular-nums">
    {years.map((yg) => (
      <div class="timeline-group">
        <div class="timeline-year mt-3 mb-1 text-[14px] uppercase tracking-wider text-ink-700 dark:text-white font-semibold">
          {yg.year}
        </div>
        {yg.months.map((m) => (
          <div class="timeline-month-wrap relative">
            <a
              href={m.url}
              class="timeline-month block py-0.5 px-1.5 rounded text-[13px] text-ink-700 dark:text-white hover:text-brand-600 dark:hover:text-brand-300 hover:bg-ink-900/10 dark:hover:bg-white/10 transition-colors text-center origin-center"
              data-month
              data-ym={`${yg.year}-${pad2(m.month)}`}
              title={`${yg.year}/${pad2(m.month)} — ${m.count} ${L.haber}`}
            >{pad2(m.month)}</a>
            <div class="timeline-days absolute left-full top-0 ml-1 hidden group-hover/month:grid bg-white dark:bg-ink-900 border border-ink-200 dark:border-ink-800 rounded-lg shadow-xl p-2 grid-cols-7 gap-1 z-10" style="min-width: 15rem;">
              <div class="col-span-7 text-[11px] uppercase tracking-wider text-ink-400 dark:text-ink-500 font-semibold mb-1">
                {yg.year}/{pad2(m.month)}
              </div>
              {m.days.map((d) => (
                <a
                  href={d.url}
                  class="timeline-day inline-grid place-items-center w-7 h-7 text-xs rounded text-ink-700 dark:text-ink-200 hover:bg-brand-50 dark:hover:bg-brand-900/30 hover:text-brand-600"
                  title={`${yg.year}/${pad2(m.month)}/${pad2(d.day)} — ${d.count} ${L.haber}`}
                >{pad2(d.day)}</a>
              ))}
            </div>
          </div>
        ))}
      </div>
    ))}
  </div>
</aside>

<style>
  .timeline-rail { width: 6.5rem; }
  .timeline-scroll::-webkit-scrollbar { width: 4px; }
  .timeline-scroll::-webkit-scrollbar-thumb { background: rgba(0,0,0,0.25); border-radius: 2px; }
  :global(html.dark) .timeline-scroll::-webkit-scrollbar-thumb { background: rgba(255,255,255,0.35); }
  .timeline-month { will-change: transform; transition: transform 120ms ease, font-weight 120ms ease; }
  /* Show day flyout on hover of the month wrapper */
  .timeline-month-wrap:hover .timeline-days { display: grid; }
</style>

<script is:inline>
  (function () {
    const rail = document.querySelector('.timeline-rail');
    if (!rail) return;
    const months = Array.from(rail.querySelectorAll('[data-month]'));
    if (!months.length) return;

    // Apple Dock-style magnification: items within DOCK_REACH pixels of cursor Y
    // scale up, peaking at DOCK_MAX right under the cursor.
    const DOCK_REACH = 90;
    const DOCK_MAX = 1.75;

    let raf = 0;
    let lastY = 0;
    let mouseActive = false;          // is the user actively hovering the rail?
    let scrollTargetY = null;         // Y position derived from scroll-spied article

    // Map YYYY-MM -> month element for fast lookup
    const monthByYm = new Map();
    for (const m of months) {
      const ym = m.getAttribute('data-ym');
      if (ym) monthByYm.set(ym, m);
    }

    function apply() {
      raf = 0;
      // While mouse is on rail, lastY follows cursor.
      // Otherwise, follow the scroll-spied article position (if any).
      const targetY = mouseActive ? lastY : scrollTargetY;
      if (targetY == null) {
        for (const m of months) {
          m.style.transform = '';
          m.style.fontWeight = '';
        }
        return;
      }
      for (const m of months) {
        const rect = m.getBoundingClientRect();
        const center = rect.top + rect.height / 2;
        const dist = Math.abs(targetY - center);
        const t = Math.max(0, 1 - dist / DOCK_REACH);
        const eased = t * t * (3 - 2 * t);
        const scale = 1 + (DOCK_MAX - 1) * eased;
        m.style.transform = 'scale(' + scale.toFixed(3) + ')';
        m.style.fontWeight = eased > 0.25 ? '700' : '400';
      }
    }

    function schedule() {
      if (!raf) raf = requestAnimationFrame(apply);
    }

    function onMove(e) {
      mouseActive = true;
      lastY = e.clientY;
      schedule();
    }

    function onLeave() {
      mouseActive = false;
      schedule();
    }

    rail.addEventListener('mousemove', onMove);
    rail.addEventListener('mouseleave', onLeave);

    // ---------- Scroll-spy: highlight the month of the most-visible article ----------
    function ymFromIso(iso) {
      if (!iso) return null;
      const m = iso.match(/(\d{4})-(\d{2})/);
      return m ? `${m[1]}-${m[2]}` : null;
    }
    function isVisible(el) {
      // Skip elements that are display:none / collapsed (e.g. the inactive
      // layout-mode container has zero size).
      const r = el.getBoundingClientRect();
      return r.width > 0 && r.height > 0;
    }

    function setActiveYm(ym) {
      if (!ym) {
        scrollTargetY = null;
        if (!mouseActive) schedule();
        return;
      }
      const el = monthByYm.get(ym);
      if (!el) {
        scrollTargetY = null;
        if (!mouseActive) schedule();
        return;
      }
      const rect = el.getBoundingClientRect();
      const railRect = rail.getBoundingClientRect();
      if (rect.top < railRect.top + 20 || rect.bottom > railRect.bottom - 20) {
        try { el.scrollIntoView({ block: 'center', behavior: 'smooth' }); } catch {}
      }
      scrollTargetY = rect.top + rect.height / 2;
      if (!mouseActive) schedule();
    }

    // Scroll-spy setup runs after DOM is ready, since Timeline is rendered
    // BEFORE articles in the page source. If we query for articles synchronously
    // at script execution time, the result is always empty.
    function initScrollSpy() {
      // Articles carry data-article-date (NewsCard, FlowCard, NewsLayout).
      const allArticles = Array.from(document.querySelectorAll('article[data-article-date]'));
      if (allArticles.length === 0) return;

      if (allArticles.length === 1) {
        // Article detail page — anchor once.
        const onlyArt = allArticles[0];
        const ym = ymFromIso(onlyArt.getAttribute('data-article-date'));
        const update = () => setActiveYm(ym);
        update();
        window.addEventListener('resize', update);
        window.addEventListener('scroll', update, { passive: true });
      } else {
        // Listing pages — track viewport-center article every scroll/resize.
        let pickRaf = 0;
        function pickBest() {
          pickRaf = 0;
          const vh = window.innerHeight || document.documentElement.clientHeight;
          const vCenter = vh / 2;
          let bestEl = null;
          let bestDist = Infinity;
          for (const el of allArticles) {
            if (!isVisible(el)) continue;
            const r = el.getBoundingClientRect();
            if (r.bottom < 0 || r.top > vh) continue;
            const c = r.top + r.height / 2;
            const dist = Math.abs(c - vCenter);
            if (dist < bestDist) { bestDist = dist; bestEl = el; }
          }
          setActiveYm(bestEl ? ymFromIso(bestEl.getAttribute('data-article-date')) : null);
        }
        function schedulePick() {
          if (!pickRaf) pickRaf = requestAnimationFrame(pickBest);
        }
        window.addEventListener('scroll', schedulePick, { passive: true });
        window.addEventListener('resize', schedulePick);
        requestAnimationFrame(schedulePick);
      }
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', initScrollSpy, { once: true });
    } else {
      initScrollSpy();
    }
  })();
</script>
