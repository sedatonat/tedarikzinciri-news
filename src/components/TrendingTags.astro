---
import { getCollection } from 'astro:content';
import { categoryLabel, categoryPath } from '../i18n/utils';
import { slugifyTag, tagPath } from '../lib/tags';
import type { Lang } from '../i18n/ui';

interface Props {
  lang: Lang;
  /** How many days back to consider for "trending" */
  days?: number;
  /** How many tags to display */
  limit?: number;
}
const { lang, days = 30, limit = 10 } = Astro.props as Props;

const collection = lang === 'tr' ? 'news-tr' : 'news-en';
const entries = await getCollection(collection, ({ data }) => !data.draft);

const cutoff = Date.now() - days * 24 * 60 * 60 * 1000;
const recent = entries.filter(e => new Date(e.data.date).getTime() >= cutoff);

// Aggregate by tag slug: count occurrences and tally categories.
type Agg = {
  display: string;
  slug: string;
  count: number;
  cats: Map<string, number>;
};
const bySlug = new Map<string, Agg>();
for (const entry of recent) {
  const cat = (entry.data.category as string) || '';
  const tags = (entry.data.tags ?? []) as string[];
  for (const raw of tags) {
    const tag = (raw || '').trim();
    if (!tag) continue;
    const slug = slugifyTag(tag);
    if (!slug) continue;
    let agg = bySlug.get(slug);
    if (!agg) {
      agg = { display: tag, slug, count: 0, cats: new Map() };
      bySlug.set(slug, agg);
    }
    agg.count += 1;
    if (cat) agg.cats.set(cat, (agg.cats.get(cat) ?? 0) + 1);
  }
}

// Sort by count desc, then alphabetical
const trending = Array.from(bySlug.values())
  .sort((a, b) =>
    b.count !== a.count
      ? b.count - a.count
      : a.display.localeCompare(b.display, lang === 'tr' ? 'tr' : 'en')
  )
  .slice(0, limit);

// Resolve top category per tag
function topCategory(cats: Map<string, number>): string {
  if (cats.size === 0) return '';
  let best = '';
  let bestCount = -1;
  for (const [c, n] of cats) {
    if (n > bestCount) { best = c; bestCount = n; }
  }
  return best;
}

const heading = lang === 'tr' ? 'Trendler' : 'Trends';
const postsLabel = (n: number) => lang === 'tr' ? `${n} gönderi` : `${n} posts`;
---
<aside class="hidden lg:block w-[330px] shrink-0">
  <div class="sticky top-20">
    <div class="rounded-2xl bg-ink-100/70 dark:bg-ink-900/70 border border-ink-200 dark:border-ink-800 overflow-hidden">
      <div class="px-4 pt-3 pb-2 flex items-center gap-2">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-5 h-5 text-brand-500" aria-hidden="true">
          <polyline points="22 7 13.5 15.5 8.5 10.5 2 17"/><polyline points="16 7 22 7 22 13"/>
        </svg>
        <h2 class="text-lg font-bold tracking-tight">{heading}</h2>
      </div>
      <ul class="divide-y divide-ink-200 dark:divide-ink-800">
        {trending.map(t => {
          const cat = topCategory(t.cats);
          const catLabel = cat ? (categoryLabel[cat]?.[lang] ?? cat) : '';
          return (
            <li class="px-4 py-3 hover:bg-ink-200/50 dark:hover:bg-ink-800/50 transition-colors">
              {catLabel && (
                <div class="text-[11px] uppercase tracking-wide text-ink-500 dark:text-ink-400">
                  <a href={categoryPath(lang, cat)} class="hover:text-brand-600 dark:hover:text-brand-400 hover:underline">{catLabel}</a>
                </div>
              )}
              <a href={tagPath(lang, t.display)} class="block group">
                <div class="font-bold text-base capitalize text-ink-900 dark:text-ink-50 leading-snug group-hover:text-brand-600 dark:group-hover:text-brand-400">
                  #{t.display}
                </div>
                <div class="text-xs text-ink-500 dark:text-ink-400 mt-0.5">{postsLabel(t.count)}</div>
              </a>
            </li>
          );
        })}
      </ul>
    </div>
  </div>
</aside>
