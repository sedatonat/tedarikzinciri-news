---
import { getCollection } from 'astro:content';
import { slugifyTag, tagPath } from '../lib/tags';
import type { Lang } from '../i18n/ui';
import { events as chronologyEvents } from '../lib/chronology';

interface Props {
  lang: Lang;
  /** How many days back to consider for "trending" */
  days?: number;
  /** How many tags to display */
  limit?: number;
}
const { lang, days = 7, limit = 10 } = Astro.props as Props;

const collection = lang === 'tr' ? 'news-tr' : 'news-en';
const entries = await getCollection(collection, ({ data }) => !data.draft);

const cutoff = Date.now() - days * 24 * 60 * 60 * 1000;
const recent = entries.filter(e => new Date(e.data.date).getTime() >= cutoff);

// Aggregate by tag slug: count occurrences (we still need count for ranking,
// even though it isn't shown in the UI anymore).
type Agg = { display: string; slug: string; count: number };
const bySlug = new Map<string, Agg>();
for (const entry of recent) {
  const tags = (entry.data.tags ?? []) as string[];
  for (const raw of tags) {
    const tag = (raw || '').trim();
    if (!tag) continue;
    const slug = slugifyTag(tag);
    if (!slug) continue;
    let agg = bySlug.get(slug);
    if (!agg) {
      agg = { display: tag, slug, count: 0 };
      bySlug.set(slug, agg);
    }
    agg.count += 1;
  }
}

// Sort by count desc, then alphabetical
const trending = Array.from(bySlug.values())
  .sort((a, b) =>
    b.count !== a.count
      ? b.count - a.count
      : a.display.localeCompare(b.display, lang === 'tr' ? 'tr' : 'en')
  )
  .slice(0, limit);

const heading = lang === 'tr' ? 'Trendler' : 'Trends';
const headingHint = lang === 'tr' ? `(son ${days} gün)` : `(last ${days} days)`;

// Chronology promo bar (sits above Trendler)
const chronoCount = chronologyEvents.length;
const chronoYears = (() => {
  const years = chronologyEvents.map(e => Number(e.date.slice(0, 4))).filter(Number.isFinite);
  if (!years.length) return '';
  const min = Math.min(...years);
  const max = Math.max(...years);
  return min === max ? `${min}` : `${min}–${max}`;
})();
const chronoLabel = lang === 'tr'
  ? `Kronoloji: ${chronoCount} olay, ${chronoYears}`
  : `Chronology: ${chronoCount} events, ${chronoYears}`;
const chronoHref = lang === 'tr' ? '/kronoloji/' : '/en/chronology/';
---
<aside class="hidden lg:block w-[330px] shrink-0">
  <!-- Sticky offset accounts for the Header (~64px) + sticky CategoryStrip
       (~73px) so the rail parks just under the frosted strip instead of
       sliding behind it. The .trending-rail-pinned class lets global.css
       slide it up alongside the header auto-hide animation, matching the
       left Timeline's behavior. -->
  <div class="trending-rail-pinned sticky top-[148px] space-y-3">
    <a
      href={chronoHref}
      class="group flex items-center gap-2.5 px-4 py-2.5 rounded-2xl border border-ink-200 dark:border-ink-800 bg-ink-100/70 dark:bg-ink-900/70 text-ink-700 dark:text-ink-200 hover:border-brand-500 hover:text-brand-700 dark:hover:text-brand-300 transition-colors"
      aria-label={chronoLabel}
    >
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" class="w-4 h-4 text-brand-500 dark:text-brand-400 shrink-0" aria-hidden="true">
        <path d="M4 6h8a3 3 0 0 1 0 6H9a3 3 0 0 0 0 6h10"/>
        <circle cx="6" cy="6" r="1.6" fill="currentColor" stroke="none"/>
        <circle cx="13" cy="12" r="1.6" fill="currentColor" stroke="none"/>
        <circle cx="11" cy="18" r="1.6" fill="currentColor" stroke="none"/>
        <path d="m17 15 3 3-3 3"/>
      </svg>
      <span class="flex-1 text-sm font-medium leading-tight truncate">{chronoLabel}</span>
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-4 h-4 text-ink-400 group-hover:translate-x-0.5 transition-transform" aria-hidden="true">
        <path d="M5 12h14"/><path d="m12 5 7 7-7 7"/>
      </svg>
    </a>
    <div class="rounded-2xl bg-ink-100/70 dark:bg-ink-900/70 border border-ink-200 dark:border-ink-800 overflow-hidden">
      <div class="px-3.5 pt-2.5 pb-1.5 flex items-center gap-1.5">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-4 h-4 text-brand-500" aria-hidden="true">
          <polyline points="22 7 13.5 15.5 8.5 10.5 2 17"/><polyline points="16 7 22 7 22 13"/>
        </svg>
        <h2 class="text-base font-bold tracking-tight">
          {heading}
          <span class="ml-1 text-xs font-normal text-ink-500 dark:text-ink-400">{headingHint}</span>
        </h2>
      </div>
      <ul>
        {trending.map(t => (
          <li class="hover:bg-ink-200/50 dark:hover:bg-ink-800/50 transition-colors">
            <a href={tagPath(lang, t.display)} class="block px-3.5 py-2 group">
              <div class="font-bold text-sm capitalize text-ink-900 dark:text-ink-50 leading-snug group-hover:text-brand-600 dark:group-hover:text-brand-400">
                #{t.display}
              </div>
            </a>
          </li>
        ))}
      </ul>
    </div>
  </div>
</aside>
