---
import { getLangFromUrl, useTranslations } from '../i18n/utils';
const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const year = new Date().getFullYear();
---
<footer class="border-t border-ink-200 dark:border-ink-800 mt-12">
  <div class="container-wide py-10 text-sm text-ink-500 dark:text-ink-400 flex flex-col sm:flex-row gap-4 justify-between">
    <p>&copy; {year} {t('site.title')}. {t('footer.rights')}</p>
    <nav class="flex gap-4">
      <a href="https://sedatonat.com" target="_blank" rel="noopener noreferrer" class="hover:text-brand-600">{t('footer.about')}</a>
      <a href="mailto:info@sedatonat.com" class="hover:text-brand-600">{t('footer.contact')}</a>
      <a href={lang === 'tr' ? '/rss.xml' : '/en/rss.xml'} class="hover:text-brand-600">{t('footer.rss')}</a>
    </nav>
  </div>
  <div class="container-wide pb-10 text-center">
    <a
      href="https://www.tedarikzinciriportali.com/"
      target="_blank"
      rel="noopener noreferrer"
      class="inline-block text-base sm:text-lg font-semibold text-brand-600 hover:text-brand-700 dark:text-brand-400 dark:hover:text-brand-300"
    >Tedarik Zinciri Portalı</a>
  </div>
</footer>
