---
import { getLangFromUrl, categoryLabel, newsPath, categoryPath } from '../i18n/utils';
import { dayUrl } from '../lib/timeline';
import { tagPath } from '../lib/tags';
import { resolveExcerpt } from '../lib/excerpt';

interface Props {
  entry: { slug: string; data: any };
}
const { entry } = Astro.props;
const lang = getLangFromUrl(Astro.url);
const href = newsPath(lang, entry.slug);
const dateObj = new Date(entry.data.date);
const date = dateObj.toLocaleDateString(
  lang === 'tr' ? 'tr-TR' : 'en-US',
  { day: 'numeric', month: 'short', year: 'numeric' }
);
const dayHref = dayUrl(
  lang,
  dateObj.getUTCFullYear(),
  dateObj.getUTCMonth() + 1,
  dateObj.getUTCDate()
);
const cat = entry.data.category;
const topTags: string[] = Array.isArray(entry.data.tags)
  ? entry.data.tags.filter((t: any) => typeof t === 'string' && t.trim()).slice(0, 3)
  : [];
let sourceHost = '';
if (entry.data.sourceUrl) {
  try {
    sourceHost = new URL(entry.data.sourceUrl).hostname.replace(/^www\./, '');
  } catch {}
}
const excerpt = resolveExcerpt(entry.data.subtitle, (entry as any).body, 220);
---
<article class="group flex flex-col rounded-xl overflow-hidden border border-ink-200 dark:border-ink-800 bg-white dark:bg-ink-900 hover:border-brand-500 transition">
  {entry.data.image && (
    <a href={href} class="block aspect-[16/9] overflow-hidden bg-ink-100 dark:bg-ink-800" aria-label={entry.data.title}>
      <img src={entry.data.image} alt={entry.data.imageAlt ?? entry.data.title}
           class="w-full h-full object-cover group-hover:scale-105 transition duration-500"
           loading="lazy" decoding="async"
           onerror="if(this.dataset.fallback!=='1'){this.dataset.fallback='1';this.src='/og-default.png';}" />
    </a>
  )}
  <div class="p-5 flex flex-col gap-2 flex-1">
    <div class="flex items-center gap-2 text-xs text-ink-500">
      <a href={categoryPath(lang, cat)} class="chip bg-brand-100 text-brand-800 dark:bg-brand-900/40 dark:text-brand-300 hover:bg-brand-200 dark:hover:bg-brand-900/60 transition-colors">{categoryLabel[cat]?.[lang] ?? cat}</a>
      <a href={dayHref} class="hover:text-brand-600 hover:underline underline-offset-4 decoration-dotted">
        <time datetime={dateObj.toISOString()}>{date}</time>
      </a>
    </div>
    {sourceHost && (
      <div class="text-xs text-ink-500">
        <a href={entry.data.sourceUrl} target="_blank" rel="noopener noreferrer nofollow"
           class="hover:text-brand-600 hover:underline underline-offset-4 decoration-dotted break-all"
           title={entry.data.sourceUrl}>{sourceHost}</a>
      </div>
    )}
    <a href={href} class="block">
      <h3 class="text-lg font-semibold leading-snug group-hover:text-brand-600">{entry.data.title}</h3>
      {excerpt && <p class="mt-2 text-sm text-ink-600 dark:text-ink-300 line-clamp-3">{excerpt}</p>}
    </a>
    <div class="mt-auto pt-2 flex flex-wrap items-center gap-x-2 gap-y-1.5 text-ink-500 dark:text-ink-400">
      <details class="share-menu relative icon-tip shrink-0" data-tip={lang === 'tr' ? 'Haberi paylaş' : 'Share news'}>
        <summary class="list-none cursor-pointer [&::-webkit-details-marker]:hidden inline-flex items-center hover:text-sky-500" aria-label={lang === 'tr' ? 'Paylaş' : 'Share'}>
          <span class="p-1 rounded-full hover:bg-sky-500/10">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" class="w-4 h-4" aria-hidden="true">
              <path d="M4 12v8a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2v-8"/><polyline points="16 6 12 2 8 6"/><line x1="12" y1="2" x2="12" y2="15"/>
            </svg>
          </span>
        </summary>
        <div class="absolute left-0 bottom-full mb-2 z-30 w-56 rounded-xl bg-white dark:bg-ink-900 border border-ink-200 dark:border-ink-800 shadow-lg overflow-hidden text-sm">
          <button data-share="copy" data-url={href} data-copied={lang === 'tr' ? 'Kopyalandı!' : 'Copied!'} type="button" class="block w-full text-left px-4 py-2.5 hover:bg-ink-100 dark:hover:bg-ink-800 text-ink-900 dark:text-ink-100 font-medium">
            <span class="share-label">{lang === 'tr' ? 'Linki Kopyala' : 'Copy link'}</span>
          </button>
          <div class="h-px bg-ink-200 dark:bg-ink-800"></div>
          <button data-share="twitter" data-url={href} data-title={entry.data.title} type="button" class="block w-full text-left px-4 py-2 hover:bg-ink-100 dark:hover:bg-ink-800 text-ink-800 dark:text-ink-100">X (Twitter)</button>
          <button data-share="linkedin" data-url={href} data-title={entry.data.title} type="button" class="block w-full text-left px-4 py-2 hover:bg-ink-100 dark:hover:bg-ink-800 text-ink-800 dark:text-ink-100">LinkedIn</button>
          <button data-share="facebook" data-url={href} data-title={entry.data.title} type="button" class="block w-full text-left px-4 py-2 hover:bg-ink-100 dark:hover:bg-ink-800 text-ink-800 dark:text-ink-100">Facebook</button>
          <button data-share="whatsapp" data-url={href} data-title={entry.data.title} type="button" class="block w-full text-left px-4 py-2 hover:bg-ink-100 dark:hover:bg-ink-800 text-ink-800 dark:text-ink-100">WhatsApp</button>
          <button data-share="telegram" data-url={href} data-title={entry.data.title} type="button" class="block w-full text-left px-4 py-2 hover:bg-ink-100 dark:hover:bg-ink-800 text-ink-800 dark:text-ink-100">Telegram</button>
          <button data-share="email" data-url={href} data-title={entry.data.title} type="button" class="block w-full text-left px-4 py-2 hover:bg-ink-100 dark:hover:bg-ink-800 text-ink-800 dark:text-ink-100">{lang === 'tr' ? 'E-posta' : 'Email'}</button>
        </div>
      </details>
      {topTags.map((tag) => (
        <a
          href={tagPath(lang, tag)}
          class="inline-flex items-center px-2 py-0.5 rounded-full text-[11px] capitalize border border-ink-200 dark:border-ink-800 bg-white dark:bg-ink-900 text-ink-700 dark:text-ink-200 hover:border-brand-500 hover:bg-brand-50 dark:hover:bg-brand-900/30 hover:text-brand-700 dark:hover:text-brand-300 transition-colors"
        >{tag}</a>
      ))}
    </div>
  </div>
</article>
