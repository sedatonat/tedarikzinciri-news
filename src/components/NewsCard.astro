---
import { getLangFromUrl, categoryLabel, newsPath } from '../i18n/utils';

interface Props {
  entry: { slug: string; body?: string; data: any };
}
const { entry } = Astro.props;
const lang = getLangFromUrl(Astro.url);
const href = newsPath(lang, entry.slug);
const date = new Date(entry.data.date).toLocaleDateString(
  lang === 'tr' ? 'tr-TR' : 'en-US',
  { day: 'numeric', month: 'short', year: 'numeric' }
);
const cat = entry.data.category;

const title: string = typeof entry.data.title === 'string' ? entry.data.title : '';
const rawSubtitle: string = typeof entry.data.subtitle === 'string' ? entry.data.subtitle : '';

function cleanBody(md: string): string {
  return md
    // strip HTML comments
    .replace(/<!--[\s\S]*?-->/g, ' ')
    // strip fenced code blocks
    .replace(/```[\s\S]*?```/g, ' ')
    // strip HTML tags
    .replace(/<[^>]+>/g, ' ')
    // images
    .replace(/!\[[^\]]*\]\([^)]+\)/g, ' ')
    // links: keep label, drop URL
    .replace(/\[([^\]]+)\]\([^)]+\)/g, '$1')
    // headings
    .replace(/^#{1,6}\s+/gm, '')
    // list bullets
    .replace(/^\s*[-+*]\s+/gm, '')
    // emphasis/quotes/backticks/underscores
    .replace(/[*_`~>]+/g, ' ')
    // HTML entities common cases
    .replace(/&nbsp;/gi, ' ')
    .replace(/&amp;/gi, '&')
    .replace(/&lt;/gi, '<')
    .replace(/&gt;/gi, '>')
    .replace(/&quot;/gi, '"')
    // collapse whitespace
    .replace(/\s+/g, ' ')
    .trim();
}

const normTitle = title.trim().toLowerCase();
const normSubtitle = rawSubtitle.trim().toLowerCase();
const hasRealSubtitle = rawSubtitle.length > 0 && normSubtitle !== normTitle;

const bodyText = cleanBody(entry.body ?? '');
const summary = hasRealSubtitle ? rawSubtitle : bodyText;

const subtitle = summary.length > 500
  ? summary.slice(0, 500).replace(/\s+\S*$/, '') + '…'
  : summary;
---
<a href={href} class="group flex flex-col rounded-xl overflow-hidden border border-ink-200 dark:border-ink-800 bg-white dark:bg-ink-900 hover:border-brand-500 transition">
  {entry.data.image && (
    <div class="aspect-[16/9] overflow-hidden bg-ink-100 dark:bg-ink-800">
      <img src={entry.data.image} alt={entry.data.imageAlt ?? entry.data.title}
           class="w-full h-full object-cover group-hover:scale-105 transition duration-500"
           loading="lazy" decoding="async"
           onerror="if(this.dataset.fallback!=='1'){this.dataset.fallback='1';this.src='/og-default.png';}" />
    </div>
  )}
  <div class="p-5 flex flex-col gap-2 flex-1">
    <div class="flex items-center gap-2 text-xs text-ink-500">
      <span class="chip bg-brand-100 text-brand-800 dark:bg-brand-900/40 dark:text-brand-300">{categoryLabel[cat]?.[lang] ?? cat}</span>
      <time datetime={new Date(entry.data.date).toISOString()}>{date}</time>
    </div>
    <h3 class="text-lg font-semibold leading-snug group-hover:text-brand-600">{entry.data.title}</h3>
    {subtitle && <p class="text-sm text-ink-600 dark:text-ink-300 leading-relaxed">{subtitle}</p>}
  </div>
</a>
