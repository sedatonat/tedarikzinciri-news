---
import { getLangFromUrl, categoryLabel, newsPath, categoryPath } from '../i18n/utils';
import { tagPath } from '../lib/tags';
import { resolveExcerpt } from '../lib/excerpt';

interface Props {
  entry: { slug: string; data: any };
}
const { entry } = Astro.props;
const lang = getLangFromUrl(Astro.url);
const href = newsPath(lang, entry.slug);
const cat = entry.data.category;
const catLabel = categoryLabel[cat]?.[lang] ?? cat;
const dateObj = new Date(entry.data.date);
const dateAbs = dateObj.toLocaleDateString(
  lang === 'tr' ? 'tr-TR' : 'en-US',
  { day: 'numeric', month: 'short', year: 'numeric' }
);

// Relative time formatter
function relativeTime(d: Date, lang: 'tr' | 'en'): string {
  const now = Date.now();
  const diffMs = now - d.getTime();
  const sec = Math.max(1, Math.floor(diffMs / 1000));
  const min = Math.floor(sec / 60);
  const hr = Math.floor(min / 60);
  const day = Math.floor(hr / 24);
  const wk = Math.floor(day / 7);
  const mo = Math.floor(day / 30);
  const yr = Math.floor(day / 365);
  if (lang === 'tr') {
    if (yr >= 1) return `${yr} yıl önce`;
    if (mo >= 1) return `${mo} ay önce`;
    if (wk >= 1) return `${wk} hafta önce`;
    if (day >= 1) return `${day} gün önce`;
    if (hr >= 1) return `${hr} saat önce`;
    if (min >= 1) return `${min} dakika önce`;
    return 'az önce';
  } else {
    if (yr >= 1) return `${yr}y ago`;
    if (mo >= 1) return `${mo}mo ago`;
    if (wk >= 1) return `${wk}w ago`;
    if (day >= 1) return `${day}d ago`;
    if (hr >= 1) return `${hr}h ago`;
    if (min >= 1) return `${min}m ago`;
    return 'just now';
  }
}
const timeLabel = relativeTime(dateObj, lang);

// Category icon color (transparent background, colored stroke)
const iconColor: Record<string, string> = {
  'Lojistik': 'text-sky-500',
  'Tedarik Zinciri': 'text-emerald-500',
  'Teknoloji': 'text-violet-500',
  'Envanter': 'text-amber-500',
  'Satınalma': 'text-rose-500',
};
const avatarColor = iconColor[cat] ?? 'text-brand-500';

// Category SVG icons (same as /kategoriler page)
const ICONS: Record<string, string> = {
  'Lojistik': '<path d="M3 17V6a1 1 0 0 1 1-1h11v12"/><path d="M15 8h4l3 4v5h-7"/><circle cx="7" cy="18" r="2"/><circle cx="17" cy="18" r="2"/>',
  'Tedarik Zinciri': '<path d="M10 13a5 5 0 0 0 7.07 0l3-3a5 5 0 0 0-7.07-7.07l-1.5 1.5"/><path d="M14 11a5 5 0 0 0-7.07 0l-3 3a5 5 0 0 0 7.07 7.07l1.5-1.5"/>',
  'Teknoloji': '<rect x="4" y="4" width="16" height="16" rx="2"/><rect x="9" y="9" width="6" height="6"/><path d="M9 2v2"/><path d="M15 2v2"/><path d="M9 20v2"/><path d="M15 20v2"/><path d="M2 9h2"/><path d="M2 15h2"/><path d="M20 9h2"/><path d="M20 15h2"/>',
  'Envanter': '<path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/><path d="m3.3 7 8.7 5 8.7-5"/><path d="M12 22V12"/>',
  'Satınalma': '<circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/><path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"/>',
};
const avatarIcon = ICONS[cat] ?? ICONS['Tedarik Zinciri'];

// Body text: subtitle preferred; falls back to an extract of the article body
const body = resolveExcerpt(entry.data.subtitle, (entry as any).body, 260);

const topTags: string[] = Array.isArray(entry.data.tags)
  ? entry.data.tags.filter((t: any) => typeof t === 'string' && t.trim()).slice(0, 3)
  : [];

// Source site hostname (e.g. "supplychainbrain.com") — mirrors NewsCard behavior
let sourceHost = '';
if (entry.data.sourceUrl) {
  try {
    sourceHost = new URL(entry.data.sourceUrl).hostname.replace(/^www\./, '');
  } catch {}
}
---
<article class="border-b border-ink-200 dark:border-ink-800 px-4 sm:px-5 py-3 hover:bg-ink-50/50 dark:hover:bg-ink-900/40 transition-colors">
  <div class="flex gap-3">
    <!-- Avatar: transparent background, category icon -->
    <a href={categoryPath(lang, cat)} class="icon-tip shrink-0" aria-label={catLabel} data-tip={lang === 'tr' ? `Kategori: ${catLabel}` : `Category: ${catLabel}`}>
      <div class={`w-10 h-10 sm:w-12 sm:h-12 rounded-full bg-transparent ${avatarColor} flex items-center justify-center ring-1 ring-ink-200 dark:ring-ink-800`}>
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-5 h-5 sm:w-6 sm:h-6" aria-hidden="true" set:html={avatarIcon} />
      </div>
    </a>

    <div class="flex-1 min-w-0">
      <!-- Header line: category name + dot + time -->
      <div class="flex flex-wrap items-center gap-x-1.5 text-sm leading-tight">
        <a href={categoryPath(lang, cat)} class="font-bold text-ink-900 dark:text-ink-100 hover:underline truncate">
          {catLabel}
        </a>
        <span class="text-ink-400 dark:text-ink-600">·</span>
        <time datetime={dateObj.toISOString()} class="text-ink-500 dark:text-ink-400" title={dateAbs}>
          {timeLabel}
        </time>
      </div>
      {sourceHost && (
        <div class="text-xs text-ink-500 dark:text-ink-400 mt-0.5 truncate">
          <a href={entry.data.sourceUrl} target="_blank" rel="noopener noreferrer nofollow"
             class="hover:text-brand-600 hover:underline underline-offset-4 decoration-dotted break-all"
             title={entry.data.sourceUrl}>{sourceHost}</a>
        </div>
      )}

      <!-- Title (bold, like a tweet's lead line) -->
      <a href={href} class="block mt-1">
        <h3 class="text-[15px] sm:text-base font-semibold text-ink-900 dark:text-ink-100 leading-snug hover:text-brand-600 dark:hover:text-brand-400">
          {entry.data.title}
        </h3>
      </a>

      <!-- Body text -->
      {body && (
        <a href={href} class="block mt-1">
          <p class="text-[15px] text-ink-700 dark:text-ink-200 leading-relaxed line-clamp-3">{body}</p>
        </a>
      )}

      <!-- Image -->
      {entry.data.image && (
        <a href={href} class="block mt-3 rounded-2xl overflow-hidden border border-ink-200 dark:border-ink-800 bg-ink-100 dark:bg-ink-800" aria-label={entry.data.title}>
          <img
            src={entry.data.image}
            alt={entry.data.imageAlt ?? entry.data.title}
            class="w-full max-h-[480px] object-cover"
            loading="lazy" decoding="async"
            onerror="if(this.dataset.fallback!=='1'){this.dataset.fallback='1';this.src='/og-default.png';}"
          />
        </a>
      )}

      <!-- Share + tags row -->
      <div class="mt-3 flex flex-wrap items-center gap-x-2 gap-y-1.5 text-ink-500 dark:text-ink-400">
        <details class="share-menu relative icon-tip shrink-0" data-tip={lang === 'tr' ? 'Haberi paylaş' : 'Share news'}>
          <summary class="list-none cursor-pointer [&::-webkit-details-marker]:hidden inline-flex items-center hover:text-sky-500" aria-label={lang === 'tr' ? 'Paylaş' : 'Share'}>
            <span class="p-1.5 rounded-full hover:bg-sky-500/10">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" class="w-[18px] h-[18px]" aria-hidden="true">
                <path d="M4 12v8a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2v-8"/><polyline points="16 6 12 2 8 6"/><line x1="12" y1="2" x2="12" y2="15"/>
              </svg>
            </span>
          </summary>
          <div class="absolute left-0 bottom-full mb-2 z-30 w-56 rounded-xl bg-white dark:bg-ink-900 border border-ink-200 dark:border-ink-800 shadow-lg overflow-hidden text-sm">
            <button data-share="copy" data-url={href} data-copied={lang === 'tr' ? 'Kopyalandı!' : 'Copied!'} type="button" class="block w-full text-left px-4 py-2.5 hover:bg-ink-100 dark:hover:bg-ink-800 text-ink-900 dark:text-ink-100 font-medium">
              <span class="share-label">{lang === 'tr' ? 'Linki Kopyala' : 'Copy link'}</span>
            </button>
            <div class="h-px bg-ink-200 dark:bg-ink-800"></div>
            <button data-share="twitter" data-url={href} data-title={entry.data.title} type="button" class="block w-full text-left px-4 py-2 hover:bg-ink-100 dark:hover:bg-ink-800 text-ink-800 dark:text-ink-100">X (Twitter)</button>
            <button data-share="linkedin" data-url={href} data-title={entry.data.title} type="button" class="block w-full text-left px-4 py-2 hover:bg-ink-100 dark:hover:bg-ink-800 text-ink-800 dark:text-ink-100">LinkedIn</button>
            <button data-share="facebook" data-url={href} data-title={entry.data.title} type="button" class="block w-full text-left px-4 py-2 hover:bg-ink-100 dark:hover:bg-ink-800 text-ink-800 dark:text-ink-100">Facebook</button>
            <button data-share="whatsapp" data-url={href} data-title={entry.data.title} type="button" class="block w-full text-left px-4 py-2 hover:bg-ink-100 dark:hover:bg-ink-800 text-ink-800 dark:text-ink-100">WhatsApp</button>
            <button data-share="telegram" data-url={href} data-title={entry.data.title} type="button" class="block w-full text-left px-4 py-2 hover:bg-ink-100 dark:hover:bg-ink-800 text-ink-800 dark:text-ink-100">Telegram</button>
            <button data-share="email" data-url={href} data-title={entry.data.title} type="button" class="block w-full text-left px-4 py-2 hover:bg-ink-100 dark:hover:bg-ink-800 text-ink-800 dark:text-ink-100">{lang === 'tr' ? 'E-posta' : 'Email'}</button>
          </div>
        </details>
        {topTags.map((tag) => (
          <a
            href={tagPath(lang, tag)}
            class="inline-flex items-center px-2 py-0.5 rounded-full text-[11px] capitalize border border-ink-200 dark:border-ink-800 bg-white dark:bg-ink-900 text-ink-600 dark:text-ink-300 hover:border-brand-500 hover:text-brand-700 dark:hover:text-brand-300 transition-colors"
          >#{tag}</a>
        ))}
      </div>
    </div>
  </div>
</article>

<script>
  (() => {
    if ((window as any).__shareMenuBound) return;
    (window as any).__shareMenuBound = true;

    const TEMPLATES: Record<string, (u: string, t: string) => string> = {
      twitter: (u, t) => `https://twitter.com/intent/tweet?text=${encodeURIComponent(t)}&url=${encodeURIComponent(u)}`,
      linkedin: (u) => `https://www.linkedin.com/sharing/share-offsite/?url=${encodeURIComponent(u)}`,
      facebook: (u) => `https://www.facebook.com/sharer/sharer.php?u=${encodeURIComponent(u)}`,
      whatsapp: (u, t) => `https://wa.me/?text=${encodeURIComponent(t + ' ' + u)}`,
      telegram: (u, t) => `https://t.me/share/url?url=${encodeURIComponent(u)}&text=${encodeURIComponent(t)}`,
      email: (u, t) => `mailto:?subject=${encodeURIComponent(t)}&body=${encodeURIComponent(u)}`,
    };

    document.addEventListener('click', (e) => {
      const target = e.target as HTMLElement;
      const btn = target.closest('[data-share]') as HTMLElement | null;
      if (btn) {
        const kind = btn.dataset.share || '';
        const rawUrl = btn.dataset.url || '';
        const title = btn.dataset.title || '';
        const absoluteUrl = new URL(rawUrl, window.location.origin).toString();

        if (kind === 'copy') {
          e.preventDefault();
          if (navigator.clipboard?.writeText) {
            navigator.clipboard.writeText(absoluteUrl).catch(() => {});
          }
          const label = btn.querySelector('.share-label') as HTMLElement | null;
          if (label) {
            const original = label.textContent;
            label.textContent = btn.dataset.copied || 'Copied!';
            setTimeout(() => { if (label) label.textContent = original; }, 1500);
          }
        } else if (TEMPLATES[kind]) {
          e.preventDefault();
          window.open(TEMPLATES[kind](absoluteUrl, title), '_blank', 'noopener,noreferrer');
        }

        const d = btn.closest('details') as HTMLDetailsElement | null;
        if (d) setTimeout(() => { d.open = false; }, kind === 'copy' ? 1400 : 200);
        return;
      }

      // Close any open share menu when clicking outside
      document.querySelectorAll('details.share-menu[open]').forEach((d) => {
        if (!d.contains(target)) (d as HTMLDetailsElement).open = false;
      });
    });

    // Close menu on Escape
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') {
        document.querySelectorAll('details.share-menu[open]').forEach((d) => {
          (d as HTMLDetailsElement).open = false;
        });
      }
    });
  })();
</script>
