---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { getLangFromUrl, useTranslations } from '../i18n/utils';

interface Props {
  title?: string;
  description?: string;
  image?: string;
  canonical?: string;
  type?: 'website' | 'article';
  alternateTr?: string;  // hreflang tr path (absolute or root-relative)
  alternateEn?: string;  // hreflang en path
  jsonLd?: object;
}

const { title, description, image, canonical, type = 'website', alternateTr, alternateEn, jsonLd } = Astro.props;
const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const siteTitle = t('site.title');
const fullTitle = title ? `${title} — ${siteTitle}` : siteTitle;
const metaDescription = description ?? t('site.tagline');
const canonicalURL = canonical ?? new URL(Astro.url.pathname, Astro.site).toString();

const siteUrl = Astro.site?.toString().replace(/\/$/, '') ?? 'https://tzp.news';

// Default OG image for social media previews. Individual pages can override via the `image` prop.
const ogImage = image ?? `${siteUrl}/og-default.png`;
const ogImageAbs = ogImage.startsWith('http') ? ogImage : `${siteUrl}${ogImage.startsWith('/') ? '' : '/'}${ogImage}`;

// Build hreflang URLs. If explicitly provided, use them; else derive from current pathname.
function abs(p: string | undefined): string | undefined {
  if (!p) return undefined;
  if (p.startsWith('http')) return p;
  return siteUrl + (p.startsWith('/') ? p : '/' + p);
}
const hrefTr = abs(alternateTr);
const hrefEn = abs(alternateEn);

// Cloudflare Web Analytics token — pulled from env at build time. Set CF_BEACON_TOKEN in GitHub Actions secrets.
const cfBeaconToken = import.meta.env.PUBLIC_CF_BEACON_TOKEN;
---
<!doctype html>
<html lang={lang} class="h-full">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{fullTitle}</title>
    <meta name="description" content={metaDescription} />
    <link rel="canonical" href={canonicalURL} />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <link rel="alternate" type="application/rss+xml" title={`${siteTitle} - TR`} href="/rss.xml" />
    <link rel="alternate" type="application/rss+xml" title={`${siteTitle} - EN`} href="/en/rss.xml" />

    {hrefTr && <link rel="alternate" hreflang="tr" href={hrefTr} />}
    {hrefEn && <link rel="alternate" hreflang="en" href={hrefEn} />}
    {(hrefTr || hrefEn) && <link rel="alternate" hreflang="x-default" href={hrefTr ?? hrefEn} />}

    <meta property="og:type" content={type} />
    <meta property="og:site_name" content={siteTitle} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={metaDescription} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:locale" content={lang === 'tr' ? 'tr_TR' : 'en_US'} />
    <meta property="og:image" content={ogImageAbs} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={fullTitle} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={metaDescription} />
    <meta name="twitter:image" content={ogImageAbs} />
    <meta name="twitter:image:alt" content={fullTitle} />

    {jsonLd && <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />}

    <script is:inline>
      (function () {
        try {
          const saved = localStorage.getItem('theme');
          const system = window.matchMedia('(prefers-color-scheme: dark)').matches;
          const dark = saved ? saved === 'dark' : system;
          if (dark) document.documentElement.classList.add('dark');
        } catch (_) {}
      })();
    </script>
    <script is:inline>
      // Akış Modu (layout): "standard" (default desktop) | "flow" (X.com-style)
      // Mobile is forced to flow via CSS regardless of this attribute.
      (function () {
        try {
          var saved = localStorage.getItem('layoutMode');
          if (saved === 'flow') {
            document.documentElement.setAttribute('data-mode', 'flow');
          }
        } catch (_) {}
      })();
    </script>

    <slot name="head" />
  </head>
  <body class="min-h-full flex flex-col">
    <Header />
    <main class="flex-1 pb-16"><slot /></main>
    <Footer />

    <!-- News popup: fetches target news page and displays it inline -->
    <div id="news-popup" class="fixed inset-0 z-[100] hidden items-start sm:items-center justify-center bg-black/60 backdrop-blur-sm p-0 sm:p-4" role="dialog" aria-modal="true" aria-hidden="true" aria-label={lang === 'tr' ? 'Haber önizleme' : 'Article preview'}>
      <div id="news-popup-panel" class="relative w-full sm:max-w-3xl h-full sm:h-auto sm:max-h-[90vh] bg-white dark:bg-ink-950 sm:rounded-2xl shadow-2xl overflow-hidden flex flex-col">
        <button id="news-popup-close" type="button" aria-label={lang === 'tr' ? 'Kapat' : 'Close'} class="absolute top-3 right-3 z-10 w-9 h-9 inline-flex items-center justify-center rounded-full bg-white/90 dark:bg-ink-800/90 backdrop-blur text-ink-700 dark:text-ink-200 hover:bg-white dark:hover:bg-ink-700 border border-ink-200 dark:border-ink-700 shadow">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="w-5 h-5" aria-hidden="true"><path fill-rule="evenodd" d="M4.293 4.293a1 1 0 011.414 0L10 8.586l4.293-4.293a1 1 0 111.414 1.414L11.414 10l4.293 4.293a1 1 0 01-1.414 1.414L10 11.414l-4.293 4.293a1 1 0 01-1.414-1.414L8.586 10 4.293 5.707a1 1 0 010-1.414z" clip-rule="evenodd" /></svg>
        </button>
        <div id="news-popup-content" class="flex-1 overflow-y-auto"></div>
        <div id="news-popup-loading" class="absolute inset-0 hidden items-center justify-center bg-white/70 dark:bg-ink-950/70 pointer-events-none">
          <div class="w-8 h-8 border-2 border-ink-300 border-t-brand-500 rounded-full animate-spin" aria-hidden="true"></div>
        </div>
      </div>
    </div>

    <script is:inline>
      (function () {
        var modal = document.getElementById('news-popup');
        var panel = document.getElementById('news-popup-panel');
        var content = document.getElementById('news-popup-content');
        var closeBtn = document.getElementById('news-popup-close');
        var loading = document.getElementById('news-popup-loading');
        if (!modal || !content) return;

        var NEWS_RE = /^\/(?:haber|en\/news)\/[^\/]+\/?$/;
        var initialPath = window.location.pathname;
        var initialIsNews = NEWS_RE.test(initialPath);
        var originalTitle = document.title;

        function showLoading(on) {
          if (!loading) return;
          if (on) { loading.classList.remove('hidden'); loading.classList.add('flex'); }
          else { loading.classList.add('hidden'); loading.classList.remove('flex'); }
        }
        function lockScroll(lock) {
          document.documentElement.style.overflow = lock ? 'hidden' : '';
          document.body.style.overflow = lock ? 'hidden' : '';
        }
        function openPopup(url, push) {
          showLoading(true);
          modal.classList.remove('hidden');
          modal.classList.add('flex');
          modal.setAttribute('aria-hidden', 'false');
          lockScroll(true);
          fetch(url, { credentials: 'same-origin', headers: { 'Accept': 'text/html' } })
            .then(function (r) { if (!r.ok) throw new Error('fetch failed'); return r.text(); })
            .then(function (html) {
              var doc = new DOMParser().parseFromString(html, 'text/html');
              var article = doc.querySelector('main article');
              if (!article) { window.location.href = url; return; }
              content.innerHTML = '';
              content.appendChild(article);
              content.scrollTop = 0;
              var titleEl = doc.querySelector('title');
              if (titleEl && titleEl.textContent) document.title = titleEl.textContent;
              if (push) {
                try { history.pushState({ newsPopup: true }, '', url); } catch (_) {}
              }
              showLoading(false);
            })
            .catch(function () {
              showLoading(false);
              window.location.href = url;
            });
        }
        function closePopup(useBack) {
          modal.classList.add('hidden');
          modal.classList.remove('flex');
          modal.setAttribute('aria-hidden', 'true');
          content.innerHTML = '';
          document.title = originalTitle;
          lockScroll(false);
          showLoading(false);
          if (useBack && history.state && history.state.newsPopup) {
            try { history.back(); } catch (_) {}
          }
        }
        function isSameOriginNews(href) {
          try {
            var u = new URL(href, window.location.origin);
            return u.origin === window.location.origin && NEWS_RE.test(u.pathname);
          } catch (e) { return false; }
        }
        document.addEventListener('click', function (e) {
          if (e.defaultPrevented) return;
          if (e.metaKey || e.ctrlKey || e.shiftKey || e.altKey || e.button !== 0) return;
          var a = e.target && e.target.closest && e.target.closest('a');
          if (!a || !a.href) return;
          if (a.target === '_blank') return;
          if (a.hasAttribute('download')) return;
          if (!isSameOriginNews(a.href)) return;
          // On a standalone news page (not opened via popup), use normal navigation
          if (initialIsNews && modal.classList.contains('hidden')) return;
          e.preventDefault();
          openPopup(a.href, true);
        });
        if (closeBtn) closeBtn.addEventListener('click', function () { closePopup(true); });
        modal.addEventListener('click', function (e) {
          if (e.target === modal) closePopup(true);
        });
        document.addEventListener('keydown', function (e) {
          if (modal.classList.contains('hidden')) return;
          // Ignore when user is typing in a form field
          var tag = e.target && e.target.tagName;
          if (tag === 'INPUT' || tag === 'TEXTAREA' || tag === 'SELECT' || (e.target && e.target.isContentEditable)) return;
          if (e.key === 'Escape') { closePopup(true); return; }
          if (e.key === 'ArrowLeft' || e.key === 'ArrowRight') {
            var dir = e.key === 'ArrowLeft' ? 'newer' : 'older';
            var link = content.querySelector('a[data-news-nav="' + dir + '"]');
            if (link && link.getAttribute('href')) {
              e.preventDefault();
              openPopup(link.getAttribute('href'), true);
            }
          }
        });
        window.addEventListener('popstate', function () {
          if (history.state && history.state.newsPopup) {
            openPopup(window.location.href, false);
          } else {
            closePopup(false);
          }
        });
      })();
    </script>

    {cfBeaconToken && (
      <script
        defer
        src="https://static.cloudflareinsights.com/beacon.min.js"
        data-cf-beacon={`{"token": "${cfBeaconToken}"}`}
      />
    )}
  </body>
</html>
