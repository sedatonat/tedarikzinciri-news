---
import { getCollection } from 'astro:content';
import BaseLayout from './BaseLayout.astro';
import { getLangFromUrl, useTranslations, categoryLabel, categoryPath } from '../i18n/utils';
import { tagPath } from '../lib/tags';
import { dayUrl } from '../lib/timeline';

interface Props {
  frontmatter: any;
  slug?: string;
  alternateSlug?: string;  // slug of same article in the other language, if any
}
const { frontmatter, slug, alternateSlug } = Astro.props;
const lang = getLangFromUrl(Astro.url);

// Compute previous / next article links (sorted by date desc)
const newsCollection = lang === 'tr' ? 'news-tr' : 'news-en';
const allEntries = await getCollection(newsCollection, ({ data }) => !data.draft);
allEntries.sort((a, b) => {
  const db = new Date(b.data.date).getTime();
  const da = new Date(a.data.date).getTime();
  if (db !== da) return db - da;
  return a.slug.localeCompare(b.slug);
});
const currentIdx = slug ? allEntries.findIndex(e => e.slug === slug) : -1;
const newerEntry = currentIdx > 0 ? allEntries[currentIdx - 1] : null;
const olderEntry = currentIdx >= 0 && currentIdx < allEntries.length - 1 ? allEntries[currentIdx + 1] : null;
const newsBase = lang === 'tr' ? '/haber/' : '/en/news/';
const newerHref = newerEntry ? `${newsBase}${newerEntry.slug}/` : null;
const olderHref = olderEntry ? `${newsBase}${olderEntry.slug}/` : null;
const newerLabel = lang === 'tr' ? 'Daha yeni haber' : 'Newer article';
const olderLabel = lang === 'tr' ? 'Daha eski haber' : 'Older article';
const t = useTranslations(lang);
const dateObj = new Date(frontmatter.date);
const date = dateObj.toLocaleDateString(
  lang === 'tr' ? 'tr-TR' : 'en-US',
  { day: 'numeric', month: 'long', year: 'numeric' }
);
const dayHref = dayUrl(
  lang,
  dateObj.getUTCFullYear(),
  dateObj.getUTCMonth() + 1,
  dateObj.getUTCDate()
);

// Build hreflang alternate URLs
const alternateTr = lang === 'tr' && slug
  ? `/haber/${slug}`
  : (alternateSlug ? `/haber/${alternateSlug}` : undefined);
const alternateEn = lang === 'en' && slug
  ? `/en/news/${slug}`
  : (alternateSlug ? `/en/news/${alternateSlug}` : undefined);

// JSON-LD Article schema
const siteUrl = Astro.site?.toString().replace(/\/$/, '') ?? 'https://tzp.news';
const canonicalUrl = new URL(Astro.url.pathname, Astro.site).toString();
const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'NewsArticle',
  headline: frontmatter.title,
  description: frontmatter.subtitle,
  image: frontmatter.image ? [frontmatter.image] : undefined,
  datePublished: new Date(frontmatter.date).toISOString(),
  dateModified: new Date(frontmatter.date).toISOString(),
  inLanguage: lang === 'tr' ? 'tr-TR' : 'en-US',
  articleSection: frontmatter.category,
  author: {
    '@type': 'Person',
    name: frontmatter.author ?? 'Sedat Onat'
  },
  publisher: {
    '@type': 'Organization',
    name: t('site.title'),
    logo: {
      '@type': 'ImageObject',
      url: `${siteUrl}/favicon.png`
    }
  },
  mainEntityOfPage: {
    '@type': 'WebPage',
    '@id': canonicalUrl
  }
};
---
<BaseLayout
  title={frontmatter.title}
  description={frontmatter.subtitle}
  image={frontmatter.image}
  type="article"
  alternateTr={alternateTr}
  alternateEn={alternateEn}
  jsonLd={jsonLd}
>
  <article class="container-narrow pt-8">
    <nav class="flex flex-wrap items-center gap-x-3 gap-y-2 text-sm text-ink-500 dark:text-ink-400 mb-6">
      <a
        href={lang === 'tr' ? '/' : '/en/'}
        data-back-link
        data-tip={lang === 'tr' ? 'Önceki sayfaya dön' : 'Go back to previous page'}
        class="icon-tip icon-tip-below inline-flex items-center gap-1.5 px-2.5 py-1 rounded-md border border-ink-200 dark:border-ink-800 bg-white dark:bg-ink-900 hover:border-brand-500 hover:text-brand-700 dark:hover:text-brand-300 transition-colors"
        aria-label={lang === 'tr' ? 'Geri dön' : 'Go back'}
      >
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="w-4 h-4" aria-hidden="true">
          <path fill-rule="evenodd" d="M12.79 5.23a.75.75 0 01-.02 1.06L8.832 10l3.938 3.71a.75.75 0 11-1.04 1.08l-4.5-4.25a.75.75 0 010-1.08l4.5-4.25a.75.75 0 011.06.02z" clip-rule="evenodd" />
        </svg>
        <span>{lang === 'tr' ? 'Geri' : 'Back'}</span>
      </a>
      <span class="text-ink-300 dark:text-ink-700">·</span>
      <a href={lang === 'tr' ? '/' : '/en/'} class="hover:text-brand-600">{lang === 'tr' ? 'Ana Sayfa' : 'Home'}</a>
      <span class="mx-1">/</span>
      <a href={lang === 'tr' ? '/kategoriler/' : '/en/categories/'} class="hover:text-brand-600">{lang === 'tr' ? 'Kategoriler' : 'Categories'}</a>
      <span class="mx-1">/</span>
      <a href={categoryPath(lang, frontmatter.category)} class="hover:text-brand-600">{categoryLabel[frontmatter.category]?.[lang] ?? frontmatter.category}</a>
    </nav>
    <header class="mb-8">
      <div class="flex items-center gap-3 text-sm text-ink-500 mb-3">
        <a href={categoryPath(lang, frontmatter.category)} class="chip bg-brand-100 text-brand-800 dark:bg-brand-900/40 dark:text-brand-300 hover:bg-brand-200">
          {categoryLabel[frontmatter.category]?.[lang] ?? frontmatter.category}
        </a>
        <a href={dayHref} class="hover:text-brand-600 hover:underline underline-offset-4 decoration-dotted">
          <time datetime={dateObj.toISOString()}>{date}</time>
        </a>
      </div>
      <div class="flex items-start gap-2 sm:gap-3">
        {newerHref ? (
          <a
            href={newerHref}
            aria-label={newerLabel}
            title={newerEntry?.data.title ?? newerLabel}
            data-tip={newerLabel}
            data-news-nav="newer"
            class="icon-tip shrink-0 mt-1 sm:mt-2 inline-flex items-center justify-center w-9 h-9 sm:w-10 sm:h-10 rounded-full border border-ink-200 dark:border-ink-800 bg-white dark:bg-ink-900 text-ink-600 dark:text-ink-300 hover:border-brand-500 hover:text-brand-700 dark:hover:text-brand-300 transition-colors"
          >
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="w-5 h-5" aria-hidden="true">
              <path fill-rule="evenodd" d="M12.79 5.23a.75.75 0 01-.02 1.06L8.832 10l3.938 3.71a.75.75 0 11-1.04 1.08l-4.5-4.25a.75.75 0 010-1.08l4.5-4.25a.75.75 0 011.06.02z" clip-rule="evenodd" />
            </svg>
          </a>
        ) : (
          <span class="shrink-0 mt-1 sm:mt-2 inline-flex items-center justify-center w-9 h-9 sm:w-10 sm:h-10 rounded-full border border-ink-200/50 dark:border-ink-800/50 text-ink-300 dark:text-ink-700" aria-hidden="true">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="w-5 h-5">
              <path fill-rule="evenodd" d="M12.79 5.23a.75.75 0 01-.02 1.06L8.832 10l3.938 3.71a.75.75 0 11-1.04 1.08l-4.5-4.25a.75.75 0 010-1.08l4.5-4.25a.75.75 0 011.06.02z" clip-rule="evenodd" />
            </svg>
          </span>
        )}
        <h1 class="flex-1 text-3xl sm:text-4xl font-bold leading-tight">{frontmatter.title}</h1>
        {olderHref ? (
          <a
            href={olderHref}
            aria-label={olderLabel}
            title={olderEntry?.data.title ?? olderLabel}
            data-tip={olderLabel}
            data-news-nav="older"
            class="icon-tip shrink-0 mt-1 sm:mt-2 inline-flex items-center justify-center w-9 h-9 sm:w-10 sm:h-10 rounded-full border border-ink-200 dark:border-ink-800 bg-white dark:bg-ink-900 text-ink-600 dark:text-ink-300 hover:border-brand-500 hover:text-brand-700 dark:hover:text-brand-300 transition-colors"
          >
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="w-5 h-5" aria-hidden="true">
              <path fill-rule="evenodd" d="M7.21 14.77a.75.75 0 01.02-1.06L11.168 10 7.23 6.29a.75.75 0 111.04-1.08l4.5 4.25a.75.75 0 010 1.08l-4.5 4.25a.75.75 0 01-1.06-.02z" clip-rule="evenodd" />
            </svg>
          </a>
        ) : (
          <span class="shrink-0 mt-1 sm:mt-2 inline-flex items-center justify-center w-9 h-9 sm:w-10 sm:h-10 rounded-full border border-ink-200/50 dark:border-ink-800/50 text-ink-300 dark:text-ink-700" aria-hidden="true">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="w-5 h-5">
              <path fill-rule="evenodd" d="M7.21 14.77a.75.75 0 01.02-1.06L11.168 10 7.23 6.29a.75.75 0 111.04-1.08l4.5 4.25a.75.75 0 010 1.08l-4.5 4.25a.75.75 0 01-1.06-.02z" clip-rule="evenodd" />
            </svg>
          </span>
        )}
      </div>
      {frontmatter.subtitle && <p class="mt-3 text-xl text-ink-600 dark:text-ink-300">{frontmatter.subtitle}</p>}
      <div class="mt-4 flex items-center gap-3 text-sm text-ink-500">
        <span><span class="text-ink-400">{t('news.author')}:</span> {frontmatter.author}</span>
      </div>
      <div class="mt-4 flex flex-wrap items-center gap-x-2 gap-y-2 text-ink-500 dark:text-ink-400">
        <details class="share-menu relative icon-tip shrink-0" data-tip={lang === 'tr' ? 'Haberi paylaş' : 'Share news'}>
          <summary class="list-none cursor-pointer [&::-webkit-details-marker]:hidden inline-flex items-center hover:text-sky-500" aria-label={lang === 'tr' ? 'Paylaş' : 'Share'}>
            <span class="p-1.5 rounded-full hover:bg-sky-500/10">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" class="w-[18px] h-[18px]" aria-hidden="true">
                <path d="M4 12v8a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2v-8"/><polyline points="16 6 12 2 8 6"/><line x1="12" y1="2" x2="12" y2="15"/>
              </svg>
            </span>
          </summary>
          <div class="absolute left-0 top-full mt-2 z-30 w-56 rounded-xl bg-white dark:bg-ink-900 border border-ink-200 dark:border-ink-800 shadow-lg overflow-hidden text-sm">
            <button data-share="copy" data-url={slug ? `${newsBase}${slug}/` : Astro.url.pathname} data-copied={lang === 'tr' ? 'Kopyalandı!' : 'Copied!'} type="button" class="block w-full text-left px-4 py-2.5 hover:bg-ink-100 dark:hover:bg-ink-800 text-ink-900 dark:text-ink-100 font-medium">
              <span class="share-label">{lang === 'tr' ? 'Linki Kopyala' : 'Copy link'}</span>
            </button>
            <div class="h-px bg-ink-200 dark:bg-ink-800"></div>
            <button data-share="twitter" data-url={slug ? `${newsBase}${slug}/` : Astro.url.pathname} data-title={frontmatter.title} type="button" class="block w-full text-left px-4 py-2 hover:bg-ink-100 dark:hover:bg-ink-800 text-ink-800 dark:text-ink-100">X (Twitter)</button>
            <button data-share="linkedin" data-url={slug ? `${newsBase}${slug}/` : Astro.url.pathname} data-title={frontmatter.title} type="button" class="block w-full text-left px-4 py-2 hover:bg-ink-100 dark:hover:bg-ink-800 text-ink-800 dark:text-ink-100">LinkedIn</button>
            <button data-share="facebook" data-url={slug ? `${newsBase}${slug}/` : Astro.url.pathname} data-title={frontmatter.title} type="button" class="block w-full text-left px-4 py-2 hover:bg-ink-100 dark:hover:bg-ink-800 text-ink-800 dark:text-ink-100">Facebook</button>
            <button data-share="whatsapp" data-url={slug ? `${newsBase}${slug}/` : Astro.url.pathname} data-title={frontmatter.title} type="button" class="block w-full text-left px-4 py-2 hover:bg-ink-100 dark:hover:bg-ink-800 text-ink-800 dark:text-ink-100">WhatsApp</button>
            <button data-share="telegram" data-url={slug ? `${newsBase}${slug}/` : Astro.url.pathname} data-title={frontmatter.title} type="button" class="block w-full text-left px-4 py-2 hover:bg-ink-100 dark:hover:bg-ink-800 text-ink-800 dark:text-ink-100">Telegram</button>
            <button data-share="email" data-url={slug ? `${newsBase}${slug}/` : Astro.url.pathname} data-title={frontmatter.title} type="button" class="block w-full text-left px-4 py-2 hover:bg-ink-100 dark:hover:bg-ink-800 text-ink-800 dark:text-ink-100">{lang === 'tr' ? 'E-posta' : 'Email'}</button>
          </div>
        </details>
        {Array.isArray(frontmatter.tags) && frontmatter.tags.map((tag: string) => (
          <a
            href={tagPath(lang, tag)}
            class="inline-flex items-center px-2.5 py-1 rounded-full text-xs capitalize border border-ink-200 dark:border-ink-800 bg-white dark:bg-ink-900 text-ink-700 dark:text-ink-200 hover:border-brand-500 hover:bg-brand-50 dark:hover:bg-brand-900/30 hover:text-brand-700 dark:hover:text-brand-300 transition-colors"
          >{tag}</a>
        ))}
      </div>
    </header>
    {frontmatter.image && (
      <figure class="mb-8">
        <img src={frontmatter.image} alt={frontmatter.imageAlt ?? frontmatter.title}
             class="w-full rounded-xl" loading="eager"
             onerror="if(this.dataset.fallback!=='1'){this.dataset.fallback='1';this.src='/og-default.png';}" />
      </figure>
    )}
    <div class="prose-article" data-pagefind-body>
      <slot />
    </div>
    {frontmatter.sourceUrl && (
      <footer class="mt-10 pt-6 border-t border-ink-200 dark:border-ink-800 text-sm">
        <p><strong>{t('news.sourceLink')}:</strong> <a href={frontmatter.sourceUrl} rel="noopener nofollow" target="_blank">{frontmatter.sourceUrl}</a></p>
      </footer>
    )}
  </article>
  <script>
    // Back button: prefer browser history when there is a real previous page
    // on the same origin; otherwise let the <a href> fallback (home) take over.
    document.addEventListener('click', (ev) => {
      const target = ev.target as HTMLElement | null;
      if (!target) return;
      const link = target.closest('[data-back-link]') as HTMLAnchorElement | null;
      if (!link) return;
      try {
        const ref = document.referrer;
        const sameOrigin = ref && new URL(ref).origin === window.location.origin;
        if (sameOrigin && window.history.length > 1) {
          ev.preventDefault();
          window.history.back();
        }
      } catch {
        /* fall through to default navigation */
      }
    });
  </script>
</BaseLayout>
