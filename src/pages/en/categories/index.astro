---
import { getCollection } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Timeline from '../../../components/Timeline.astro';
import { categoryLabel, categorySlug } from '../../../i18n/utils';

const CATS = ['Lojistik', 'Tedarik Zinciri', 'Teknoloji', 'Envanter', 'Satınalma'] as const;

const all = await getCollection('news-en', ({ data }) => !data.draft);
const counts: Record<string, number> = {};
for (const c of CATS) counts[c] = 0;
for (const entry of all) {
  const c = entry.data.category;
  if (c in counts) counts[c]++;
  const secs = entry.data.secondaryCategories ?? [];
  for (const s of secs) {
    if (s in counts && s !== c) counts[s]++;
  }
}

const ICONS: Record<string, string> = {
  'Lojistik': '<path d="M3 17V6a1 1 0 0 1 1-1h11v12"/><path d="M15 8h4l3 4v5h-7"/><circle cx="7" cy="18" r="2"/><circle cx="17" cy="18" r="2"/>',
  'Tedarik Zinciri': '<path d="M10 13a5 5 0 0 0 7.07 0l3-3a5 5 0 0 0-7.07-7.07l-1.5 1.5"/><path d="M14 11a5 5 0 0 0-7.07 0l-3 3a5 5 0 0 0 7.07 7.07l1.5-1.5"/>',
  'Teknoloji': '<rect x="4" y="4" width="16" height="16" rx="2"/><rect x="9" y="9" width="6" height="6"/><path d="M9 2v2"/><path d="M15 2v2"/><path d="M9 20v2"/><path d="M15 20v2"/><path d="M2 9h2"/><path d="M2 15h2"/><path d="M20 9h2"/><path d="M20 15h2"/>',
  'Envanter': '<path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/><path d="m3.3 7 8.7 5 8.7-5"/><path d="M12 22V12"/>',
  'Satınalma': '<circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/><path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"/>'
};
---
<BaseLayout title="Categories" alternateTr="/kategoriler/" alternateEn="/en/categories/">
  <Timeline lang="en" />
  <section class="container-wide py-10">
    <nav class="text-sm text-ink-500 dark:text-ink-400 mb-3">
      <a href="/en/" class="hover:text-brand-600">Home</a>
      <span class="mx-2">/</span>
      <span>Categories</span>
    </nav>
    <h1 class="sticky top-16 z-30 bg-transparent text-3xl sm:text-4xl font-bold mb-2 py-2">Categories</h1>
    <p class="text-ink-600 dark:text-ink-300 mb-8">Pick a category to see its articles.</p>

    <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-5 gap-4 sm:gap-6">
      {CATS.map(cat => (
        <a
          href={`/en/category/${categorySlug(cat)}`}
          class="group flex flex-col items-center justify-center text-center gap-3 p-6 rounded-2xl border border-ink-200 dark:border-ink-800 bg-white dark:bg-ink-900 hover:border-brand-500 hover:shadow-md hover:-translate-y-0.5 transition-all"
        >
          <span class="inline-grid place-items-center w-14 h-14 rounded-2xl bg-brand-50 dark:bg-brand-900/30 text-brand-600 dark:text-brand-300 group-hover:bg-brand-100 dark:group-hover:bg-brand-900/50 transition-colors">
            <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" set:html={ICONS[cat]} />
          </span>
          <span class="font-semibold text-base sm:text-lg">{categoryLabel[cat].en}</span>
          <span class="text-sm text-ink-500 dark:text-ink-400">{counts[cat]} articles</span>
        </a>
      ))}
    </div>
  </section>
</BaseLayout>
