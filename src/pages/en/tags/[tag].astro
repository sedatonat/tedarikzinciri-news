---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import NewsCard from '../../../components/NewsCard.astro';
import Timeline from '../../../components/Timeline.astro';
import { getAllTags, getArticlesByTag } from '../../../lib/tags';

export async function getStaticPaths() {
  const tags = await getAllTags('en');
  return tags.map(t => ({
    params: { tag: t.slug },
    props: { display: t.tag, count: t.count }
  }));
}

const { tag } = Astro.params;
const { display, count } = Astro.props as { display: string; count: number };
const articles = await getArticlesByTag('en', tag as string);
---
<BaseLayout
  title={`${display} — Tag`}
  description={`${count} articles tagged "${display}".`}
>
  <Timeline lang="en" />
  <section class="container-wide py-10">
    <nav class="text-sm text-ink-500 dark:text-ink-400 mb-3">
      <a href="/en/" class="hover:text-brand-600">Home</a>
      <span class="mx-2">/</span>
      <span class="capitalize">{display}</span>
    </nav>
    <h1 class="sticky top-16 z-30 bg-transparent text-3xl sm:text-4xl font-bold capitalize mb-2 py-2">{display}</h1>
    <p class="text-ink-600 dark:text-ink-300 mb-8">{count} articles</p>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
      {articles.map(e => <NewsCard entry={e} />)}
    </div>
  </section>
</BaseLayout>
