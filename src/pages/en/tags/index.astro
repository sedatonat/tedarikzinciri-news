---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Timeline from '../../../components/Timeline.astro';
import { getAllTags, tagPath } from '../../../lib/tags';

const tags = await getAllTags('en');
---
<BaseLayout
  title="Tags"
  description="Tags automatically generated from article content."
  alternateTr="/etiketler/"
  alternateEn="/en/tags/"
>
  <Timeline lang="en" />
  <section class="container-wide py-10">
    <nav class="text-sm text-ink-500 dark:text-ink-400 mb-3">
      <a href="/en/" class="hover:text-brand-600">Home</a>
      <span class="mx-2">/</span>
      <span>Tags</span>
    </nav>
    <h1 class="sticky top-16 z-30 bg-transparent text-3xl sm:text-4xl font-bold mb-2 py-2">Tags</h1>
    <p class="text-ink-600 dark:text-ink-300 mb-8">
      Click a tag to see every article marked with it.
      Total <strong>{tags.length}</strong> tags.
    </p>

    {tags.length === 0 ? (
      <div class="rounded-2xl border border-ink-200 dark:border-ink-800 bg-white dark:bg-ink-900 p-8 text-center text-ink-500 dark:text-ink-400">
        No tags yet. Tags will appear here after <code>scripts/auto_tag.py</code> runs.
      </div>
    ) : (
      <div class="flex flex-wrap gap-2">
        {tags.map(t => (
          <a
            href={tagPath('en', t.tag)}
            class="group inline-flex items-center gap-2 px-3 py-1.5 rounded-full border border-ink-200 dark:border-ink-800 bg-white dark:bg-ink-900 hover:border-brand-500 hover:bg-brand-50 dark:hover:bg-brand-900/30 transition-colors"
          >
            <span class="font-medium capitalize text-ink-800 dark:text-ink-100 group-hover:text-brand-700 dark:group-hover:text-brand-300">{t.tag}</span>
            <span class="text-xs text-ink-500 dark:text-ink-400 tabular-nums">{t.count}</span>
          </a>
        ))}
      </div>
    )}
  </section>
</BaseLayout>
