---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import NewsCard from '../../components/NewsCard.astro';
import Pagination from '../../components/Pagination.astro';
import Timeline from '../../components/Timeline.astro';
import { useTranslations } from '../../i18n/utils';

const PAGE_SIZE = 24;
const t = useTranslations('en');
const all = (await getCollection('news-en', ({ data }) => !data.draft))
  .sort((a, b) => new Date(b.data.date).valueOf() - new Date(a.data.date).valueOf());

const currentPage = 1;
const lastPage = Math.max(1, Math.ceil(all.length / PAGE_SIZE));
const items = all.slice(0, PAGE_SIZE);

const page = {
  url: {
    current: '/en',
    first: '/en',
    last: lastPage > 1 ? `/en/page/${lastPage}` : '/en',
    prev: undefined,
    next: lastPage > 1 ? '/en/page/2' : undefined,
  },
  currentPage,
  lastPage
};
---
<BaseLayout>
  <Timeline lang="en" />
  <section class="container-wide pt-10 pb-8">
    <h1 class="text-4xl sm:text-5xl font-bold tracking-tight">{t('site.title')}</h1>
    <p class="mt-3 text-lg text-ink-600 dark:text-ink-300 max-w-2xl">{t('site.tagline')}</p>
  </section>
  <section class="container-wide pb-12">
    <h2 class="text-2xl font-semibold mb-6">{t('home.latest')}</h2>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
      {items.map(e => <NewsCard entry={e} />)}
    </div>
    {lastPage > 1 && <Pagination page={page} labelPrev={t('pagination.prev')} labelNext={t('pagination.next')} />}
  </section>
</BaseLayout>
