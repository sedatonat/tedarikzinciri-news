---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import NewsCard from '../../components/NewsCard.astro';
import FlowCard from '../../components/FlowCard.astro';
import Timeline from '../../components/Timeline.astro';
import TrendingTags from '../../components/TrendingTags.astro';
import CategoryStrip from '../../components/CategoryStrip.astro';
import { websiteSchema, organizationSchema } from '../../lib/seo';

const items = (await getCollection('news-en', ({ data }) => !data.draft))
  .sort((a, b) => new Date(b.data.date).valueOf() - new Date(a.data.date).valueOf());

const jsonLd = [websiteSchema('en'), organizationSchema('en')];
---
<BaseLayout jsonLd={jsonLd}>
  <Timeline lang="en" />
  <CategoryStrip lang="en" />
  <section class="container-wide pt-6 pb-12">
    <div class="standard-grid grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
      {items.map(e => <NewsCard entry={e} />)}
    </div>
    <div class="flow-grid flex-row justify-center gap-8 max-w-5xl mx-auto">
      <div class="w-full max-w-2xl border-x border-ink-200 dark:border-ink-800">
        {items.map(e => <FlowCard entry={e} />)}
      </div>
      <TrendingTags lang="en" />
    </div>
  </section>
</BaseLayout>
