---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Timeline from '../../components/Timeline.astro';
import { useTranslations } from '../../i18n/utils';

const t = useTranslations('en');
---
<BaseLayout title={t('search.title')}>
  <Timeline lang="en" />
  <section class="container-narrow pt-10 pb-12">
    <nav class="text-sm text-ink-500 dark:text-ink-400 mb-3">
      <a href="/en/" class="hover:text-brand-600">Home</a>
      <span class="mx-2">/</span>
      <span>{t('search.title')}</span>
    </nav>
    <h1 class="sticky top-16 z-30 bg-transparent text-3xl font-bold mb-6 py-2">{t('search.title')}</h1>
    <div id="search"></div>
  </section>

  <link rel="stylesheet" href="/pagefind/pagefind-ui.css" slot="head" />
  <script is:inline src="/pagefind/pagefind-ui.js"></script>
  <script is:inline>
    window.addEventListener('DOMContentLoaded', () => {
      if (!window.PagefindUI) return;
      new window.PagefindUI({
        element: '#search',
        showImages: true,
        showSubResults: true,
        translations: {
          placeholder: 'Search news…',
          clear_search: 'Clear',
          load_more: 'Load more results',
          search_label: 'Search',
          filters_label: 'Filters',
          zero_results: 'No results for "[SEARCH_TERM]".',
          many_results: '[COUNT] results for "[SEARCH_TERM]".',
          one_result: '1 result for "[SEARCH_TERM]".',
          searching: 'Searching "[SEARCH_TERM]"…'
        }
      });
    });
  </script>
</BaseLayout>
