---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Timeline from '../../../components/Timeline.astro';
import BackButton from '../../../components/BackButton.astro';
import CategoryStrip from '../../../components/CategoryStrip.astro';
import { events, type EventKind } from '../../../lib/chronology';

const sorted = [...events].sort((a, b) => (a.date < b.date ? 1 : -1));

const KIND_META: Record<EventKind, { en: string; dot: string; ring: string; chip: string; border: string; text: string; icon: string }> = {
  attack:       { en: 'Attack',      dot: 'bg-rose-500',     ring: 'ring-rose-500/30',     border: 'border-rose-500',     text: 'text-rose-500',     chip: 'bg-rose-100 text-rose-800 dark:bg-rose-900/40 dark:text-rose-300',         icon: '<circle cx="12" cy="12" r="3"/><path d="M12 2v4M12 18v4M4.93 4.93l2.83 2.83M16.24 16.24l2.83 2.83M2 12h4M18 12h4M4.93 19.07l2.83-2.83M16.24 7.76l2.83-2.83"/>' },
  ceasefire:    { en: 'Ceasefire',   dot: 'bg-emerald-500',  ring: 'ring-emerald-500/30',  border: 'border-emerald-500',  text: 'text-emerald-500',  chip: 'bg-emerald-100 text-emerald-800 dark:bg-emerald-900/40 dark:text-emerald-300', icon: '<path d="M12 21s-7-4.35-7-10a5 5 0 0 1 9-3 5 5 0 0 1 9 3c0 5.65-7 10-7 10z"/><path d="M8 12h8"/>' },
  accident:     { en: 'Accident',    dot: 'bg-amber-500',    ring: 'ring-amber-500/30',    border: 'border-amber-500',    text: 'text-amber-500',    chip: 'bg-amber-100 text-amber-800 dark:bg-amber-900/40 dark:text-amber-300',     icon: '<path d="M10.29 3.86 1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/>' },
  collision:    { en: 'Collision',   dot: 'bg-orange-500',   ring: 'ring-orange-500/30',   border: 'border-orange-500',   text: 'text-orange-500',   chip: 'bg-orange-100 text-orange-800 dark:bg-orange-900/40 dark:text-orange-300', icon: '<polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/>' },
  tariff:       { en: 'Tariff',      dot: 'bg-violet-500',   ring: 'ring-violet-500/30',   border: 'border-violet-500',   text: 'text-violet-500',   chip: 'bg-violet-100 text-violet-800 dark:bg-violet-900/40 dark:text-violet-300', icon: '<path d="M20.59 13.41 13.41 20.59a2 2 0 0 1-2.83 0L2 12V2h10l8.59 8.59a2 2 0 0 1 0 2.82z"/><circle cx="7.5" cy="7.5" r="1.4" fill="currentColor"/>' },
  sanction:     { en: 'Sanction',    dot: 'bg-red-600',      ring: 'ring-red-500/30',      border: 'border-red-600',      text: 'text-red-600',      chip: 'bg-red-100 text-red-800 dark:bg-red-900/40 dark:text-red-300',              icon: '<circle cx="12" cy="12" r="10"/><line x1="4.93" y1="4.93" x2="19.07" y2="19.07"/>' },
  agreement:    { en: 'Agreement',   dot: 'bg-sky-500',      ring: 'ring-sky-500/30',      border: 'border-sky-500',      text: 'text-sky-500',      chip: 'bg-sky-100 text-sky-800 dark:bg-sky-900/40 dark:text-sky-300',              icon: '<path d="M11 4H5a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-6"/><path d="M14 2l8 8-10 10H6v-6L14 2z"/>' },
  acquisition:  { en: 'Acquisition', dot: 'bg-indigo-500',   ring: 'ring-indigo-500/30',   border: 'border-indigo-500',   text: 'text-indigo-500',   chip: 'bg-indigo-100 text-indigo-800 dark:bg-indigo-900/40 dark:text-indigo-300', icon: '<path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/><path d="m3.3 7 8.7 5 8.7-5"/><path d="M12 22V12"/>' },
  drought:      { en: 'Drought',     dot: 'bg-yellow-600',   ring: 'ring-yellow-500/30',   border: 'border-yellow-600',   text: 'text-yellow-600',   chip: 'bg-yellow-100 text-yellow-800 dark:bg-yellow-900/40 dark:text-yellow-300', icon: '<path d="M12 2.69l5.66 5.66a8 8 0 1 1-11.31 0z"/>' },
  cyber:        { en: 'Cyber attack', dot: 'bg-fuchsia-500', ring: 'ring-fuchsia-500/30',  border: 'border-fuchsia-500',  text: 'text-fuchsia-500',  chip: 'bg-fuchsia-100 text-fuchsia-800 dark:bg-fuchsia-900/40 dark:text-fuchsia-300', icon: '<rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/>' },
  strike:       { en: 'Strike',       dot: 'bg-teal-500',     ring: 'ring-teal-500/30',     border: 'border-teal-500',     text: 'text-teal-500',     chip: 'bg-teal-100 text-teal-800 dark:bg-teal-900/40 dark:text-teal-300',         icon: '<path d="M18 8a3 3 0 0 0-3-3h-1a3 3 0 0 0-3 3v1"/><path d="M10 12v10"/><path d="M14 12v10"/><path d="M8 12h8"/><path d="M6 9l12 0"/>' },
};

function formatDateEn(iso: string): string {
  const d = new Date(iso + 'T00:00:00Z');
  const months = ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'];
  return `${months[d.getUTCMonth()]} ${d.getUTCDate()}, ${d.getUTCFullYear()}`;
}
---
<BaseLayout
  title="Chronology"
  description="Headline-making attacks, decisions, accidents, ceasefires and major acquisitions in supply chain, shipping and trade — ordered by date."
  alternateTr="/kronoloji/"
  alternateEn="/en/chronology/"
>
  <Timeline lang="en" />
  <CategoryStrip lang="en" />
  <section class="container-wide pt-6 pb-10">
    <div class="flex items-center flex-wrap gap-3 mb-3 text-sm">
      <BackButton />
      <span class="text-ink-400 dark:text-ink-600" aria-hidden="true">·</span>
      <nav class="text-ink-500 dark:text-ink-400">
        <a href="/en/" class="hover:text-brand-600">Home</a>
        <span class="mx-2">/</span>
        <span>Chronology</span>
      </nav>
    </div>

    <h1 class="text-3xl sm:text-4xl font-bold mb-2">Chronology</h1>
    <p class="text-ink-600 dark:text-ink-300 mb-8 max-w-2xl">
      Headline-making attacks, decisions, accidents, ceasefires and major acquisitions — ordered by date. Each event links to its source article.
    </p>

    <div class="flex flex-wrap items-center gap-2 mb-10" id="chrono-filter">
      {(Object.keys(KIND_META) as EventKind[]).map(k => (
        <button
          type="button"
          data-filter={k}
          aria-pressed="false"
          class={`chrono-chip inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full text-xs font-medium cursor-pointer ${KIND_META[k].chip} transition-opacity`}
        >
          <span class={`inline-block w-1.5 h-1.5 rounded-full ${KIND_META[k].dot}`}></span>
          {KIND_META[k].en}
        </button>
      ))}
      <button
        type="button"
        data-filter-reset
        class="hidden ml-1 px-2.5 py-1 rounded-full text-xs font-medium text-ink-600 dark:text-ink-300 border border-ink-300 dark:border-ink-700 hover:border-brand-500 hover:text-brand-600 transition-colors"
      >Show all</button>
      <span data-filter-count class="hidden text-xs text-ink-500 dark:text-ink-400 ml-1"></span>
    </div>

    <div class="relative max-w-5xl mx-auto">
      <div class="md:hidden absolute left-4 top-2 bottom-2 w-px bg-ink-200 dark:bg-ink-800" aria-hidden="true"></div>
      <div class="hidden md:block absolute left-1/2 top-0 bottom-0 w-px bg-ink-200 dark:bg-ink-800 -translate-x-1/2" aria-hidden="true"></div>

      <ol data-chrono-list class="space-y-6 md:space-y-10">
        {sorted.map((e, i) => {
          const meta = KIND_META[e.kind];
          const isEven = i % 2 === 0;
          const href = `/en/news/${e.slug}/`;
          return (
            <li data-kind={e.kind}>
              <div class="md:hidden relative pl-12">
                <span class={`absolute left-0 top-1 flex items-center justify-center w-8 h-8 rounded-full bg-white dark:bg-ink-950 border-2 ring-4 ${meta.ring} ${meta.border} shrink-0`} aria-hidden="true">
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class={`w-4 h-4 ${meta.text}`} set:html={meta.icon} />
                </span>
                <a href={href} class="group block">
                  <div class="text-xs font-mono text-ink-500 dark:text-ink-400 mb-1">{formatDateEn(e.date)}</div>
                  <span class={`inline-flex items-center gap-1.5 px-2.5 py-0.5 rounded-full text-[11px] font-medium ${meta.chip} mb-2`}>
                    <span class={`inline-block w-1.5 h-1.5 rounded-full ${meta.dot}`}></span>
                    {meta.en}
                  </span>
                  <h3 class="text-base font-semibold leading-snug text-ink-900 dark:text-ink-100 group-hover:text-brand-600 dark:group-hover:text-brand-400 transition-colors">{e.title_en}</h3>
                  <p class="mt-1 text-sm text-ink-600 dark:text-ink-300">{e.summary_en}</p>
                </a>
              </div>

              <div class="hidden md:grid grid-cols-[1fr_auto_1fr] items-center gap-x-8">
                <div class={isEven ? 'text-right' : ''}>
                  {isEven && (
                    <a href={href} class="group block">
                      <div class="text-xs font-mono text-ink-500 dark:text-ink-400 mb-1">{formatDateEn(e.date)}</div>
                      <span class={`inline-flex items-center gap-1.5 px-2.5 py-0.5 rounded-full text-[11px] font-medium ${meta.chip} mb-2`}>
                        <span class={`inline-block w-1.5 h-1.5 rounded-full ${meta.dot}`}></span>
                        {meta.en}
                      </span>
                      <h3 class="text-lg font-semibold leading-snug text-ink-900 dark:text-ink-100 group-hover:text-brand-600 dark:group-hover:text-brand-400 transition-colors">{e.title_en}</h3>
                      <p class="mt-1 text-sm text-ink-600 dark:text-ink-300">{e.summary_en}</p>
                    </a>
                  )}
                </div>

                <span class={`flex items-center justify-center w-10 h-10 rounded-full bg-white dark:bg-ink-950 border-2 ring-4 ${meta.ring} ${meta.border} shrink-0 relative z-10`} aria-hidden="true">
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class={`w-5 h-5 ${meta.text}`} set:html={meta.icon} />
                </span>

                <div>
                  {!isEven && (
                    <a href={href} class="group block">
                      <div class="text-xs font-mono text-ink-500 dark:text-ink-400 mb-1">{formatDateEn(e.date)}</div>
                      <span class={`inline-flex items-center gap-1.5 px-2.5 py-0.5 rounded-full text-[11px] font-medium ${meta.chip} mb-2`}>
                        <span class={`inline-block w-1.5 h-1.5 rounded-full ${meta.dot}`}></span>
                        {meta.en}
                      </span>
                      <h3 class="text-lg font-semibold leading-snug text-ink-900 dark:text-ink-100 group-hover:text-brand-600 dark:group-hover:text-brand-400 transition-colors">{e.title_en}</h3>
                      <p class="mt-1 text-sm text-ink-600 dark:text-ink-300">{e.summary_en}</p>
                    </a>
                  )}
                </div>
              </div>
            </li>
          );
        })}
      </ol>
      <p data-filter-empty class="hidden text-sm text-ink-500 dark:text-ink-400 text-center py-12">No events match the selected filter.</p>
    </div>
  </section>

  <script is:inline>
    (function () {
      const filterRoot = document.getElementById('chrono-filter');
      const list = document.querySelector('ol[data-chrono-list]') || document.querySelector('section ol');
      if (!filterRoot || !list) return;
      const items = Array.from(list.querySelectorAll('li[data-kind]'));
      if (!items.length) return;
      const chips = Array.from(filterRoot.querySelectorAll('[data-filter]'));
      const reset = filterRoot.querySelector('[data-filter-reset]');
      const counter = filterRoot.querySelector('[data-filter-count]');
      const empty = document.querySelector('[data-filter-empty]');

      const active = new Set();

      function render() {
        let visible = 0;
        for (const li of items) {
          const k = li.getAttribute('data-kind') || '';
          const show = active.size === 0 || active.has(k);
          li.style.display = show ? '' : 'none';
          if (show) visible++;
        }
        for (const chip of chips) {
          const on = active.has(chip.getAttribute('data-filter'));
          chip.setAttribute('aria-pressed', on ? 'true' : 'false');
          chip.style.opacity = active.size === 0 || on ? '1' : '0.4';
        }
        if (active.size > 0) {
          reset.classList.remove('hidden');
          counter.classList.remove('hidden');
          counter.textContent = visible + ' events';
        } else {
          reset.classList.add('hidden');
          counter.classList.add('hidden');
        }
        empty.classList.toggle('hidden', visible !== 0);
      }

      for (const chip of chips) {
        chip.addEventListener('click', function () {
          const k = chip.getAttribute('data-filter');
          if (!k) return;
          if (active.has(k)) active.delete(k);
          else active.add(k);
          render();
        });
      }
      reset.addEventListener('click', function () {
        active.clear();
        render();
      });
    })();
  </script>
</BaseLayout>
