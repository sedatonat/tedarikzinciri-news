---
import BaseLayout from '../../layouts/BaseLayout.astro';
import NewsCard from '../../components/NewsCard.astro';
import Timeline from '../../components/Timeline.astro';
import BackButton from '../../components/BackButton.astro';
import { getAllTags, getArticlesByTag } from '../../lib/tags';

export async function getStaticPaths() {
  const tags = await getAllTags('tr');
  return tags.map(t => ({
    params: { tag: t.slug },
    props: { display: t.tag, count: t.count }
  }));
}

const { tag } = Astro.params;
const { display, count } = Astro.props as { display: string; count: number };
const articles = await getArticlesByTag('tr', tag as string);
---
<BaseLayout
  title={`${display} — Etiket`}
  description={`"${display}" etiketiyle işaretlenmiş ${count} haber.`}
>
  <Timeline lang="tr" />
  <section class="container-wide py-10">
    <div class="flex items-center flex-wrap gap-3 mb-3 text-sm">
      <BackButton />
      <span class="text-ink-400 dark:text-ink-600" aria-hidden="true">·</span>
      <nav class="text-ink-500 dark:text-ink-400">
        <a href="/" class="hover:text-brand-600">Ana Sayfa</a>
        <span class="mx-2">/</span>
        <span>Etiketler</span>
        <span class="mx-2">/</span>
        <span class="capitalize">{display}</span>
      </nav>
    </div>
    <h1 class="sticky top-16 z-30 bg-transparent text-3xl sm:text-4xl font-bold capitalize mb-2 py-2">{display}</h1>
    <p class="text-ink-600 dark:text-ink-300 mb-8">{count} haber</p>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
      {articles.map(e => <NewsCard entry={e} />)}
    </div>
  </section>
</BaseLayout>
