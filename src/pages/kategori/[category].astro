---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import NewsCard from '../../components/NewsCard.astro';
import FlowCard from '../../components/FlowCard.astro';
import Timeline from '../../components/Timeline.astro';
import TrendingTags from '../../components/TrendingTags.astro';
import CategoryStrip from '../../components/CategoryStrip.astro';
import { categoryLabel, categorySlug } from '../../i18n/utils';
import { collectionPageSchema, breadcrumbSchema, SITE_URL } from '../../lib/seo';

export async function getStaticPaths() {
  const cats = ['Lojistik','Tedarik Zinciri','Teknoloji','Envanter','Satınalma'];
  return cats.map(cat => ({ params: { category: categorySlug(cat) }, props: { cat } }));
}
const { cat } = Astro.props;
const all = (await getCollection('news-tr', ({ data }) =>
    (data.category === cat || (data.secondaryCategories ?? []).includes(cat)) && !data.draft))
  .sort((a, b) => new Date(b.data.date).valueOf() - new Date(a.data.date).valueOf());
const label = categoryLabel[cat].tr;

const pageUrl = `${SITE_URL}/kategori/${categorySlug(cat)}`;
const jsonLd = [
  collectionPageSchema({
    lang: 'tr',
    name: `${label} — Haberler`,
    description: `${label} kategorisinde son haberler ve gelişmeler.`,
    url: pageUrl,
    itemCount: all.length,
  }),
  breadcrumbSchema([
    { name: 'Ana Sayfa', url: '/' },
    { name: label },
  ]),
];
---
<BaseLayout title={label} jsonLd={jsonLd}>
  <Timeline lang="tr" />
  <CategoryStrip lang="tr" />
  <section class="container-wide pt-6 pb-10">
    <h1 class="sticky top-16 z-30 bg-transparent text-3xl sm:text-4xl font-bold mb-2 py-2">{label}</h1>
    <p class="text-ink-600 dark:text-ink-300 mb-8">{all.length} haber</p>
    <div class="standard-grid grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
      {all.map(e => <NewsCard entry={e} />)}
    </div>
    <div class="flow-grid flex-row justify-center gap-8 max-w-5xl mx-auto">
      <div class="w-full max-w-2xl border-x border-ink-200 dark:border-ink-800">
        {all.map(e => <FlowCard entry={e} />)}
      </div>
      <TrendingTags lang="tr" />
    </div>
  </section>
</BaseLayout>
